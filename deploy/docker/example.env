# privacyIDEA application config. Every key here is loaded into all three roles.
# The variable name is the loader prefix "PRIVACYIDEA_" plus the config key, so a
# key that is itself PI_-prefixed (most of privacyIDEA's own keys) reads as
# PRIVACYIDEA_PI_...  — e.g. the config key PI_PREFERRED_LANGUAGE below.

# Preferred UI languages, most-preferred first (JSON list). Leave unset to keep
# the built-in default order (English first).
#PRIVACYIDEA_PI_PREFERRED_LANGUAGE=["en","de"]

# Public base URL of this server, e.g. https://privacyidea.example.com. Used for
# password-recovery links and the {url} tag in notifications; it is never derived
# from the (untrusted) HTTP Host header. If unset, privacyIDEA logs a warning and
# disables password recovery. Set it to the URL your users actually reach:
#PRIVACYIDEA_PI_BASE_URL=https://privacyidea.example.com
