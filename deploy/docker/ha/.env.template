# PrivacyIDEA HA Stack Environment Configuration
# Copy this file to .env and adjust as needed.
#
# All sensitive credentials (SECRET_KEY, PI_PEPPER, passwords) are managed as
# Docker secrets in the secrets/ directory — NOT as environment variables.
# See README.md for how to generate them.

# ===== BOOTSTRAP ADMIN =====
# Username for the initial admin account created on first startup.
# The password is stored in secrets/bootstrap_admin_password.
BOOTSTRAP_ADMIN=admin

# ===== OPTIONAL: Advanced Configuration =====
# Number of Gunicorn workers per PI instance (default: 2)
# PI_WORKERS=2

# Database connection pool recycle time in seconds (default: 250)
# Should be less than ProxySQL/database timeout
# SQLALCHEMY_POOL_RECYCLE=250
