msgid "TiQR Registration Server"
msgstr "ເຊີບເວີລົງທະບຽນ TiQR"

#: privacyidea/static/components/config/views/config.token.tiqr.html:41
msgid ""
"TiQR Service\n"
"        Identifier"
msgstr ""
"ຕົວລະບຸ\n"
"        ບໍລິການ TiQR"

#: privacyidea/static/components/config/views/config.token.tiqr.html:32
msgid "TiQR Service Displayname"
msgstr "ຊື່ສະແດງຜົນບໍລິການ TiQR"

#: privacyidea/static/components/config/views/config.token.tiqr.html:1
msgid "TiQR Token settings"
msgstr "ການຕັ້ງຄ່າໂທເຄັນ TiQR"

#: privacyidea/static/components/config/views/config.resolvers.http.advanced.html:217
msgid "Time in seconds privacyIDEA tries to reach the user store server."
msgstr ""
"ເວລາເປັນວິນາທີທີ່ privacyIDEA ຈະພະຍາຍາມຕິດຕໍ່ເຊີບເວີບ່ອນເກັບຂໍ້ມູນຜູ້ໃຊ້."

#: privacyidea/static/components/config/views/config.radius.edit.html:46
#: privacyidea/static/components/config/views/config.smtp.edit.html:46
msgid "Timeout"
msgstr "ໝົດເວລາ (Timeout)"

#: privacyidea/static/components/config/views/config.mresolvers.ldap.html:143
#: privacyidea/static/components/config/views/config.resolvers.http.advanced.html:213
#: privacyidea/static/components/config/views/config.resolvers.ldap.html:186
msgid "Timeout (seconds)"
msgstr "ໝົດເວລາ (ວິນາທີ)"

#: privacyidea/static/components/login/factories/u2f.js:31
msgid "Timeout while waiting for signing response."
msgstr "ໝົດເວລາໃນຂະນະທີ່ລໍຖ້າການຕອບຮັບການລົງລາຍເຊັນ."

#: privacyidea/static/components/token/views/token.enroll.daypassword.html:48
#: privacyidea/static/components/token/views/token.enroll.totp.html:61
msgid "Timestep"
msgstr "ໄລຍະເວລາ (Timestep)"

#: privacyidea/static/components/components/views/component.subscriptions.html:38
msgid "To"
msgstr "ເຖິງ"

#: privacyidea/static/components/token/views/token.applications.ssh.html:12
msgid "To define service IDs go to <a ui-sref=\"config.serviceid\">Service ID config</a>"
msgstr ""
"ເພື່ອລະບຸ ID ບໍລິການ ໃຫ້ໄປທີ່ <a ui-sref=\"config.serviceid\">ການຕັ້ງຄ່າ Service ID</a>"

#: privacyidea/static/components/token/views/token.enroll.radius.html:9
msgid ""
"To ease the enrolling of RADIUS tokens you can\n"
"    set default values in the\n"
"    <a ui-sref=\"config.tokens({tokentype:'radius'})\">RADIUS Token Config</a>."
msgstr ""
