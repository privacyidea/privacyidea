#: privacyidea/static/components/token/views/token.enroll.applspec.html:1
msgid ""
"The Application Specific Password Token is a static password,\n"
"    that can be bound to certain services. This static password then can only be used to authenticate\n"
"    at this service."
msgstr ""

#: privacyidea/static/components/config/views/config.token.tiqr.html:22
msgid ""
