# privacyIDEA development environment variables — template
#
# Copy this file to .env and uncomment/adjust the values you need.
# The .env file is gitignored so your local settings won't be committed.
#
# In PyCharm: Edit Run/Debug Configuration → EnvFile tab → add .env.
#
# Two configuration mechanisms exist:
#   1. Point PRIVACYIDEA_CONFIGFILE to a pi.cfg file that sets everything.
#   2. Set individual PRIVACYIDEA_<KEY> vars — Flask strips the prefix and
#      injects the key directly into app.config (via from_prefixed_env).
#      Example: PRIVACYIDEA_PI_REDIS_URL  →  app.config["PI_REDIS_URL"]
#
# Both can be combined; individual env vars override the config file.


# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------

#FLASK_APP=privacyidea.app:create_app
#FLASK_DEBUG=1


# ---------------------------------------------------------------------------
# Config selection
#
# Selects which Config class is loaded (development/testing/production/docker).
# Read directly from os.environ (no PRIVACYIDEA_ prefix needed).
# ---------------------------------------------------------------------------

#PI_CONFIG_NAME=development


# ---------------------------------------------------------------------------
# Config file
#
# Path to an additional pi.cfg that is loaded on top of the selected Config
# class. Values in this file override the class defaults.
# ---------------------------------------------------------------------------

#PRIVACYIDEA_CONFIGFILE=/etc/privacyidea/pi.cfg


# ---------------------------------------------------------------------------
# Database
#
# Option A: full URI
# ---------------------------------------------------------------------------

#PRIVACYIDEA_SQLALCHEMY_DATABASE_URI=sqlite:///data-dev.sqlite
#PRIVACYIDEA_SQLALCHEMY_DATABASE_URI=mysql+pymysql://privacyidea:privacyidea@127.0.0.1:3306/privacyidea
#PRIVACYIDEA_SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://privacyidea:privacyidea@127.0.0.1:5432/privacyidea

# Option B: individual components (used by DockerConfig to build the URI)
# These are read directly from os.environ (no PRIVACYIDEA_ prefix).
#PI_DB_DRIVER=mysql+pymysql
#PI_DB_HOST=127.0.0.1
#PI_DB_PORT=3306
#PI_DB_NAME=privacyidea
#PI_DB_USER=privacyidea
#PI_DB_PASSWORD=privacyidea
#PI_DB_EXTRA_PARAMS=charset=utf8mb4

# Read password from file instead of directly (Docker secrets pattern):
#PI_DB_PASSWORD_FILE=/run/secrets/db_password


# ---------------------------------------------------------------------------
# Redis cache (optional — remove to disable)
# ---------------------------------------------------------------------------

PI_REDIS_URL=redis://127.0.0.1:6379/0

# Per-feature flags. PI_REDIS_URL on its own does nothing — each cacheable
# workload has its own opt-in flag so they can be rolled out independently.
PI_REDIS_CACHE_CHALLENGES=true

# Read URL from file instead:
#PI_REDIS_URL_FILE=/run/secrets/redis_url


# ---------------------------------------------------------------------------
# Encryption / secrets
# ---------------------------------------------------------------------------

#PRIVACYIDEA_SECRET_KEY=change-me-in-production
#PRIVACYIDEA_PI_PEPPER=change-me-in-production
#PRIVACYIDEA_PI_ENCFILE=/etc/privacyidea/enckey

# File-based variants (Docker secrets pattern):
#SECRET_KEY_FILE=/run/secrets/secret_key
#PI_PEPPER_FILE=/run/secrets/pi_pepper
#PI_ENCFILE=/run/secrets/enckey       (path to key file, not the key itself)


# ---------------------------------------------------------------------------
# Audit
# ---------------------------------------------------------------------------

#PRIVACYIDEA_PI_AUDIT_MODULE=privacyidea.lib.auditmodules.sqlaudit
#PRIVACYIDEA_PI_AUDIT_SQL_URI=sqlite:///audit.sqlite
#PRIVACYIDEA_PI_AUDIT_KEY_PRIVATE=/etc/privacyidea/private.pem
#PRIVACYIDEA_PI_AUDIT_KEY_PUBLIC=/etc/privacyidea/public.pem
#PRIVACYIDEA_PI_AUDIT_SERVERNAME=privacyidea
#PRIVACYIDEA_PI_AUDIT_SQL_TRUNCATE=1
#PRIVACYIDEA_PI_AUDIT_NO_SIGN=1
#PRIVACYIDEA_PI_AUDIT_POOL_SIZE=5
#PRIVACYIDEA_PI_AUDIT_POOL_RECYCLE=30


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

#PRIVACYIDEA_PI_LOGLEVEL=10          # 10=DEBUG 20=INFO 30=WARNING 40=ERROR
#PRIVACYIDEA_PI_LOGFILE=/var/log/privacyidea/privacyidea.log
#PRIVACYIDEA_PI_LOGCONFIG=/etc/privacyidea/logging.cfg


# ---------------------------------------------------------------------------
# HA / node identity
# ---------------------------------------------------------------------------

#PRIVACYIDEA_PI_NODE=node1
#PRIVACYIDEA_PI_NODE_UUID=8e4272a9-9037-40df-8aa3-976e4a04b5a9
#PRIVACYIDEA_PI_UUID_FILE=/etc/privacyidea/uuid.txt


# ---------------------------------------------------------------------------
# Security / TLS
# ---------------------------------------------------------------------------

#PRIVACYIDEA_PI_ENABLE_CSP=1
#PRIVACYIDEA_PI_FORCE_HTTPS=1
#PRIVACYIDEA_PI_SESSION_COOKIE_SECURE=1
#PRIVACYIDEA_PI_NO_RESPONSE_SIGN=1


# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------

#PRIVACYIDEA_SUPERUSER_REALM=superuser
#PRIVACYIDEA_PI_INITIALIZE_HSM=1
#PRIVACYIDEA_PI_STATIC_FOLDER=privacyidea/static/
#PRIVACYIDEA_PI_TEMPLATE_FOLDER=privacyidea/static/templates/
