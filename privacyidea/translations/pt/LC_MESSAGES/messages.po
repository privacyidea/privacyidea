msgstr "Admin é autorizado a copiar o PIN de um token para outro token."

#: lib/policy.py:1797
msgid ""
"Admin is allowed to copy the assigned user to another token, i.e. assign a "
"user to another token."
msgstr ""
"Admin é autorizado a copiar o utilizador associado para outro token, ou "
"seja, associar um utilizador a outro token."

