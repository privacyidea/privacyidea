#: api/register.py:124
msgid "No SMTP server configuration specified!"
msgstr "ບໍ່ໄດ້ລະບຸການຕັ້ງຄ່າເຊີບເວີ SMTP!"

#: api/register.py:138
msgid "No resolver specified to register in!"
msgstr "ບໍ່ໄດ້ລະບຸຣີຊອລເວີເພື່ອລົງທະບຽນ!"

#: api/register.py:145
msgid "The username is already registered!"
msgstr "ຊື່ຜູ້ໃຊ້ນີ້ຖືກລົງທະບຽນໄປແລ້ວ!"

#: api/register.py:176
msgid "Failed to send email!"
msgstr "ສົ່ງອີເມວບໍ່ສຳເລັດ!"

#: api/system.py:325
#, python-brace-format
msgid "Usage: {0!s}"
msgstr "ວິທີໃຊ້: {0!s}"

#: api/system.py:343
msgid "You need to provide the config key to delete."
msgstr "ທ່ານຕ້ອງລະບຸຄີການຕັ້ງຄ່າເພື່ອລຶບ."

#: api/token.py:1115
msgid ""
"The Pre Shared Key must be 128 Bit hex encoded. It must be 32 characters "
"long!"
msgstr ""
"Pre Shared Key ຕ້ອງເປັນການເຂົ້າລະຫັດແບບ hex 128 ບິດ ແລະ ຕ້ອງມີຄວາມຍາວ 32 ຕົວອັກສອນ!"

#: api/token.py:1140
msgid "Error loading token file. File empty!"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການໂຫຼດໄຟລ໌ໂທເຄັນ. ໄຟລ໌ຫວ່າງເປົ່າ!"

#: api/token.py:1146
#, python-brace-format
msgid "Unknown file type: '{file_type}'. Supported file types are: {known_types}"
msgstr ""
"ບໍ່ຮູ້ຈັກປະເພດໄຟລ໌: '{file_type}'. ປະເພດໄຟລ໌ທີ່ຮອງຮັບແມ່ນ: {known_types}"

#: api/token.py:1258
#, python-brace-format
msgid "The user {0!r} does not own the token {1!s}"
msgstr "ຜູ້ໃຊ້ {0!r} ບໍ່ໄດ້ເປັນເຈົ້າຂອງໂທເຄັນ {1!s}"

#: api/user.py:154
#, python-brace-format
msgid ""
"Invalid attribute name! The name shall not start with {prefix}. This is "
"an internally used prefix."
msgstr ""
"ຊື່ແອັດທຣີບິວບໍ່ຖືກຕ້ອງ! ຊື່ບໍ່ຄວນຂຶ້ນຕົ້ນດ້ວຍ {prefix}. ນີ້ແມ່ນພຣີຟິກທີ່ໃຊ້ພາຍໃນ."

#: api/validate.py:219
msgid "The token does not exist"
msgstr "ໂທເຄັນນີ້ບໍ່ມີຢູ່"

#: api/validate.py:226
msgid "The token is not valid."
msgstr "ໂທເຄັນບໍ່ຖືກຕ້ອງ."

#: api/validate.py:239
msgid "Machine can not be identified by user agent!"
msgstr "ບໍ່ສາມາດລະບຸເຄື່ອງໄດ້ໂດຍໃຊ້ຢູເຊີເອເຈນ!"

#: api/validate.py:255
msgid "Token is not an offline token or refill token is incorrect"
msgstr "ໂທເຄັນບໍ່ແມ່ນໂທເຄັນແບບອອບໄລນ໌ ຫຼື ໂທເຄັນຣີຟິວບໍ່ຖືກຕ້ອງ"

#: api/validate.py:495
msgid "Cancelled enrollment via multichallenge"
msgstr "ຍົກເລີກການລົງທະບຽນຜ່ານມັລຕິແຊລເລນຈ໌ແລ້ວ"

#: api/validate.py:496
msgid "Cancelled enrollment via multichallenge for transaction_id "
msgstr "ຍົກເລີກການລົງທະບຽນຜ່ານມັລຕິແຊລເລນຈ໌ສຳລັບ transaction_id "

#: api/validate.py:498
msgid "Failed to cancel enrollment via multichallenge"
msgstr "ຍົກເລີກການລົງທະບຽນຜ່ານມັລຕິແຊລເລນຈ໌ບໍ່ສຳເລັດ"

#: api/validate.py:499
msgid "Failed to cancel enrollment via multichallenge for transaction_id "
msgstr "ຍົກເລີກການລົງທະບຽນຜ່ານມັລຕິແຊລເລນຈ໌ສຳລັບ transaction_id ບໍ່ສຳເລັດ "

#: api/validate.py:536 api/validate.py:996
msgid "The authentication method is not available."
msgstr "ວິທີການຢືນຢັນຕົວຕົນນີ້ບໍ່ສາມາດໃຊ້ໄດ້."

#: api/validate.py:577
#, python-brace-format
msgid "Last authentication policy check failed for token {serial}"
msgstr ""
"ການກວດສອບນະໂຍບາຍການຢືນຢັນຕົວຕົນຄັ້ງຫຼ້າສຸດສຳລັບໂທເຄັນ {serial} ບໍ່ສຳເລັດ"

#: api/validate.py:601 lib/token.py:2678
