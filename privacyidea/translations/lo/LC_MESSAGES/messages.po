#: lib/policy.py:2175
msgid "Admin is allowed to list templates and view their details."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ສະແດງລາຍຊື່ເທມເພລດ ແລະ ເບິ່ງລາຍລະອຽດຂອງມັນ."

#: lib/policy.py:2180
msgid ""
"A whitespace-separated list of container info keys that shall not be "
"displayed to the admin."
msgstr ""
"ລາຍການຄີຂໍ້ມູນຄອນເທນເນີທີ່ແຍກດ້ວຍຊ່ອງຫວ່າງ ເຊິ່ງຈະບໍ່ຖືກສະແດງໃຫ້ຜູ້ດູແລລະບົບເຫັນ."

#: lib/policy.py:2187
msgid ""
"The user is allowed to assign an existing token that is not yet assigned "
"using the token serial number."
msgstr ""
"ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ມອບໝາຍໂທເຄັນທີ່ມີຢູ່ແລ້ວເຊິ່ງຍັງບໍ່ໄດ້ມອບໝາຍ ໂດຍໃຊ້ເລກຊີຣຽນຂອງໂທເຄັນ."

#: lib/policy.py:2193
msgid "The user is allowed to disable his own tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ປິດໃຊ້ງານໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2197
msgid "The user is allowed to enable his own tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເປີດໃຊ້ງານໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2201
msgid "The user is allowed to delete his own tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2205
msgid "The user is allowed to unassign his own tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຍົກເລີກການມອບໝາຍໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2209
msgid "The user is allowed to resynchronize his tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຣີຊິ້ງໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2213
msgid "The user is allowed to revoke a token"
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຖອນຄືນໂທເຄັນ"

#: lib/policy.py:2217
msgid "The user is allowed to reset the failcounter of his tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຣີເຊັດ failcounter ຂອງໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2221
msgid "The user is allowed to set the OTP PIN of his tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ຂອງໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2225
msgid "The user is allowed to set a random OTP PIN of his tokens."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ແບບສຸ່ມຂອງໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2230
msgid "The length of a random PIN set by the user."
msgstr "ຄວາມຍາວຂອງ PIN ແບບສຸ່ມທີ່ຕັ້ງໂດຍຜູ້ໃຊ້."

#: lib/policy.py:2233
msgid "The user is allowed to set the token description."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງຄຳອະທິບາຍໂທເຄັນ."

#: lib/policy.py:2237
msgid "The user is allowed to set the OTP PIN during enrollment."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/policy.py:2255
msgid "Allow the user to view his own token history."
msgstr "ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ເບິ່ງປະຫວັດໂທເຄັນຂອງຕົນເອງ."

#: lib/policy.py:2258
msgid "The user will only see audit entries of the last 10d, 3m or 2y."
msgstr "ຜູ້ໃຊ້ຈະເຫັນພຽງແຕ່ລາຍການກວດສອບຂອງ 10 ວັນ, 3 ເດືອນ ຫຼື 2 ປີທີ່ຜ່ານມາ."

#: lib/policy.py:2261
msgid "The user will not see the specified columns in the audit."
msgstr "ຜູ້ໃຊ້ຈະບໍ່ເຫັນຄໍລຳທີ່ລະບຸໄວ້ໃນການກວດສອບ."

#: lib/policy.py:2265
msgid "The user is allowed to view his own user information."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເບິ່ງຂໍ້ມູນຜູ້ໃຊ້ຂອງຕົນເອງ."

#: lib/policy.py:2268
msgid ""
"The user is allowed to update his own user information, like changing his"
" password."
msgstr ""
"ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ອັບເດດຂໍ້ມູນຜູ້ໃຊ້ຂອງຕົນເອງ ເຊັ່ນ: ການປ່ຽນລະຫັດຜ່ານ."

#: lib/policy.py:2273
msgid "The user is allowed to do a password reset in an editable UserIdResolver."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຣີເຊັດລະຫັດຜ່ານໃນ UserIdResolver ທີ່ແກ້ໄຂໄດ້."

#: lib/policy.py:2278
msgid ""
"The user is allowed to set certain custom user attributes. If the user "
"should be allowed to set any attribute, set this to '*:*'. Use '*' with "
"CAUTION! For more details, check the documentation."
msgstr ""
"ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງແອັດທຣີບິວຜູ້ໃຊ້ແບບກຳນົດເອງບາງຢ່າງ. ຖ້າຜູ້ໃຊ້ຄວນໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງແອັດທຣີບິວໃດກໍ"
"ໄດ້, ໃຫ້ຕັ້ງເປັນ '*:*'. ໃຊ້ '*' ດ້ວຍຄວາມລະມັດລະວັງ! ສຳລັບລາຍລະອຽດເພີ່ມເຕີມ, ໃຫ້ກວດສອບເອກະສາ"
"ນ."

#: lib/policy.py:2285
msgid ""
"The user is allowed to delete certain custom user attributes. If the user"
" should be allowed to delete any attribute, set this to '*'. Use '*' with"
" CAUTION! For more details, check the documentation."
msgstr ""
"ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບແອັດທຣີບິວຜູ້ໃຊ້ແບບກຳນົດເອງບາງຢ່າງ. ຖ້າຜູ້ໃຊ້ຄວນໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບແອັດທຣີບິວໃດກໍ"
"ໄດ້, ໃຫ້ຕັ້ງເປັນ '*'. ໃຊ້ '*' ດ້ວຍຄວາມລະມັດລະວັງ! ສຳລັບລາຍລະອຽດເພີ່ມເຕີມ, ໃຫ້ກວດສອບເອກະສານ."

#: lib/policy.py:2293
msgid ""
"A whitespace-separated list of tokeninfo fields which are not displayed "
"to the user."
msgstr ""
"ລາຍການຟິວ tokeninfo ທີ່ແຍກດ້ວຍຊ່ອງຫວ່າງ ເຊິ່ງຈະບໍ່ຖືກສະແດງໃຫ້ຜູ້ໃຊ້ເຫັນ."

#: lib/policy.py:2299
msgid "Users are allowed to edit the state of their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ແກ້ໄຂສະຖານະຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2304
msgid "Users are allowed to edit the description of their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ແກ້ໄຂຄຳອະທິບາຍຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2308
msgid "Users are allowed to create containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ສ້າງຄອນເທນເນີ."

#: lib/policy.py:2312
msgid "Users are allowed to delete their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2317
msgid "Users are allowed to add their own tokens to their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເພີ່ມໂທເຄັນຂອງຕົນເອງໃສ່ຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2322
msgid "Users are allowed to remove their own tokens from their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເອົາໂທເຄັນຂອງຕົນເອງອອກຈາກຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2328
msgid "Users are allowed to assign themselves to containers without an owner."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ມອບໝາຍຕົນເອງໃຫ້ກັບຄອນເທນເນີທີ່ບໍ່ມີເຈົ້າຂອງ."

#: lib/policy.py:2334
msgid "Users are allowed to unassign themselves from containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຍົກເລີກການມອບໝາຍຕົນເອງຈາກຄອນເທນເນີ."

#: lib/policy.py:2338
msgid "Users are allowed to list their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ສະແດງລາຍຊື່ຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2343
msgid "Users are allowed to register their own containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ລົງທະບຽນຄອນເທນເນີຂອງຕົນເອງ."

#: lib/policy.py:2347
msgid "Users are allowed to unregister containers."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ຍົກເລີກການລົງທະບຽນຄອນເທນເນີ."

#: lib/policy.py:2352
msgid ""
"Users are allowed to perform a container rollover of their own "
"containers. This includes a rollover of all contained tokens even if the "
"user is not the owner of a contained token."
msgstr ""
"ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ດຳເນີນການຄອນເທນເນີໂຣລໂອເວີຂອງຕົນເອງ. ນີ້ລວມທັງການໂຣລໂອເວີໂທເຄັນທັງໝົດທີ່ບັນຈຸ"
"ຢູ່ ເຖິງແມ່ນວ່າຜູ້ໃຊ້ຈະບໍ່ແມ່ນເຈົ້າຂອງໂທເຄັນທີ່ບັນຈຸຢູ່ນັ້ນກໍຕາມ."

#: lib/policy.py:2359
msgid "Users are allowed to create and edit container templates."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ສ້າງ ແລະ ແກ້ໄຂເທມເພລດຄອນເທນເນີ."

#: lib/policy.py:2363
msgid "Users are allowed to delete templates."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບເທມເພລດ."

#: lib/policy.py:2368
msgid "Users are allowed to list templates and view their details."
msgstr "ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ສະແດງລາຍຊື່ເທມເພລດ ແລະ ເບິ່ງລາຍລະອຽດຂອງມັນ."

#: lib/policy.py:2373
msgid ""
"A whitespace-separated list of container info keys that shall not be "
"displayed to the users."
msgstr ""
"ລາຍການຄີຂໍ້ມູນຄອນເທນເນີທີ່ແຍກດ້ວຍຊ່ອງຫວ່າງ ເຊິ່ງຈະບໍ່ຖືກສະແດງໃຫ້ຜູ້ໃຊ້ເຫັນ."

#: lib/policy.py:2380
msgid "Limit the number of allowed tokens in a realm."
msgstr "ຈຳກັດຈຳນວນໂທເຄັນທີ່ອະນຸຍາດໃນເຣມ."

#: lib/policy.py:2384
msgid ""
"During the rollout process, this policy makes the description required "
"for all selected tokentypes."
msgstr ""
"ໃນລະຫວ່າງຂະບວນການໂຣລເອົາ, ນະໂຍບາຍນີ້ເຮັດໃຫ້ຄຳອະທິບາຍມີຄວາມຈຳເປັນສຳລັບທຸກປະເພດໂທເຄັນທີ່ເລືອກ."

#: lib/policy.py:2392
msgid "Limit the number of tokens a user may have assigned."
msgstr "ຈຳກັດຈຳນວນໂທເຄັນທີ່ຜູ້ໃຊ້ສາມາດມອບໝາຍໄດ້."

#: lib/policy.py:2397
msgid "Limit the number of active tokens a user may have assigned."
msgstr "ຈຳກັດຈຳນວນໂທເຄັນທີ່ໃຊ້ງານຢູ່ທີ່ຜູ້ໃຊ້ສາມາດມອບໝາຍໄດ້."

#: lib/policy.py:2402
msgid ""
"Set a random OTP PIN with this length for a token during the enrollment "
"process."
msgstr ""
"ຕັ້ງຄ່າ OTP PIN ແບບສຸ່ມດ້ວຍຄວາມຍາວນີ້ສຳລັບໂທເຄັນໃນລະຫວ່າງຂະບວນການລົງທະບຽນ."

#: lib/policy.py:2407
msgid "In case of a random OTP PIN use this python module to process the PIN."
msgstr "ໃນກໍລະນີທີ່ເປັນ OTP PIN ແບບສຸ່ມ ໃຫ້ໃຊ້ໂມດູນໄພທອນນີ້ເພື່ອປະມວນຜົນ PIN."

#: lib/policy.py:2412
msgid ""
"If the administrator sets the OTP PIN during enrollment or later, the "
"user will have to change the PIN during first use."
msgstr ""
"ຖ້າຜູ້ດູແລລະບົບຕັ້ງ OTP PIN ໃນລະຫວ່າງການລົງທະບຽນ ຫຼື ພາຍຫຼັງ, ຜູ້ໃຊ້ຈະຕ້ອງປ່ຽນ PIN ໃນລະຫວ່າງການໃ"
"ຊ້ງານຄັ້ງທຳອິດ."

#: lib/policy.py:2419
msgid ""
"The user needs to change his PIN on a regular basis. To change the PIN "
"every 180 days, enter '180d'."
msgstr ""
"ຜູ້ໃຊ້ຈຳເປັນຕ້ອງປ່ຽນ PIN ຂອງຕົນເອງເປັນປະຈຳ. ເພື່ອປ່ຽນ PIN ທຸກໆ 180 ວັນ, ໃຫ້ປ້ອນ '180d'."

#: lib/policy.py:2426
msgid ""
"The OTP PIN can be hashed or encrypted. Hashing the PIN is the default "
"behaviour."
msgstr "OTP PIN ສາມາດຖືກແຮຊ ຫຼື ເຂົ້າລະຫັດ. ການແຮຊ PIN ແມ່ນພຶດຕິກຳເລີ່ມຕົ້ນ."

#: lib/policy.py:2431
#, python-brace-format
msgid ""
"The label for a new enrolled Smartphone token. Possible tags are "
"<code>{user}</code>, <code>{realm}</code>, <code>{serial}</code>, "
"<code>{givenname}</code> and <code>{surname}</code>."
msgstr ""
"ປ້າຍກຳກັບສຳລັບໂທເຄັນສະມາດໂຟນທີ່ລົງທະບຽນໃໝ່. ແທັກທີ່ເປັນໄປໄດ້ຄື <code>{user}</code>, <code>"
"{realm}</code>, <code>{serial}</code>, <code>{givenname}</code> ແລະ <code>"
"{surname}</code>."

#: lib/policy.py:2437
#, python-brace-format
msgid ""
"The issuer label for new enrolled Smartphone token.Possible tags are "
"<code>{user}</code>, <code>{realm}</code>, <code>{serial}</code>, "
"<code>{givenname}</code> and <code>{surname}</code>."
msgstr ""
"ປ້າຍກຳກັບຜູ້ອອກສຳລັບໂທເຄັນສະມາດໂຟນທີ່ລົງທະບຽນໃໝ່. ແທັກທີ່ເປັນໄປໄດ້ຄື <code>{user}</code>, "
"<code>{realm}</code>, <code>{serial}</code>, <code>{givenname}</code> ແລະ "
"<code>{surname}</code>."

#: lib/policy.py:2444
msgid ""
"This is the URL to the token image for the privacyIDEA Authenticator and "
"some other apps like FreeOTP (supported file formats: PNG, JPG and GIF)."
msgstr ""
"ນີ້ແມ່ນ URL ໄປຫາຮູບໂທເຄັນສຳລັບ privacyIDEA Authenticator ແລະ ແອັບອື່ນໆ ເຊັ່ນ FreeOTP (ຮອ"
"ງຮັບຟໍແມັດໄຟລ໌: PNG, JPG ແລະ GIF)."

#: lib/policy.py:2451
msgid ""
"Users can assign a token just by using the unassigned token to "
"authenticate."
msgstr ""
"ຜູ້ໃຊ້ສາມາດມອບໝາຍໂທເຄັນໄດ້ໂດຍພຽງແຕ່ໃຊ້ໂທເຄັນທີ່ບໍ່ໄດ້ມອບໝາຍໃນການຢືນຢັນຕົວຕົນ."

#: lib/policy.py:2457
msgid "The length of the password in case of temporary token (lost token)."
msgstr "ຄວາມຍາວຂອງລະຫັດຜ່ານໃນກໍລະນີໂທເຄັນຊົ່ວຄາວ (ໂທເຄັນທີ່ເສຍຫາຍ)."

#: lib/policy.py:2461
msgid ""
"The contents of the temporary password, described by the characters C, c,"
" n, s, 8."
msgstr "ເນື້ອຫາຂອງລະຫັດຜ່ານຊົ່ວຄາວ, ອະທິບາຍໂດຍຕົວອັກສອນ C, c, n, s, 8."

#: lib/policy.py:2466
msgid "The length of the validity for the temporary token (in days)."
msgstr "ຄວາມຍາວຂອງຄວາມຖືກຕ້ອງສຳລັບໂທເຄັນຊົ່ວຄາວ (ເປັນວັນ)."

#: lib/policy.py:2471
msgid "Set the length of registration codes."
msgstr "ຕັ້ງຄ່າຄວາມຍາວຂອງລະຫັດລົງທະບຽນ."

#: lib/policy.py:2475
msgid ""
"Specify the required contents of the registration code. (c)haracters, "
"(n)umeric, (s)pecial. Use modifiers +/- or a list of allowed characters "
"[1234567890]"
msgstr ""
"ລະບຸເນື້ອຫາທີ່ຕ້ອງການຂອງລະຫັດລົງທະບຽນ. (c)haracters, (n)umeric, (s)pecial. ໃຊ້ຕົວດັດແປງ "
"+/- ຫຼື ລາຍການຕົວອັກສອນທີ່ອະນຸຍາດ [1234567890]"

#: lib/policy.py:2484
msgid "Set the length of the password of generated password tokens."
msgstr "ຕັ້ງຄ່າຄວາມຍາວຂອງລະຫັດຜ່ານຂອງໂທເຄັນລະຫັດຜ່ານທີ່ຖືກສ້າງຂຶ້ນ."

#: lib/policy.py:2488
msgid ""
"Specify the required contents of the password of a password token. "
"(c)haracters, (n)umeric, (s)pecial. Use modifiers +/- or a list of "
"allowed characters [1234567890]"
msgstr ""
"ລະບຸເນື້ອຫາທີ່ຕ້ອງການຂອງລະຫັດຜ່ານຂອງໂທເຄັນລະຫັດຜ່ານ. (c)haracters, (n)umeric, (s)"
"pecial. ໃຊ້ຕົວດັດແປງ +/- ຫຼື ລາຍການຕົວອັກສອນທີ່ອະນຸຍາດ [1234567890]"

#: lib/policy.py:2496
msgid ""
"Specify the email validator that should be used to validate email "
"addresses during enrollment."
msgstr "ລະບຸຕົວຢືນຢັນອີເມວທີ່ຄວນໃຊ້ເພື່ອຢືນຢັນທີ່ຢູອີເມວໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/policy.py:2502
msgid "Specify the list of token types, that must be verified during enrollment."
msgstr "ລະບຸລາຍການປະເພດໂທເຄັນ ທີ່ຕ້ອງຖືກຢືນຢັນໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/policy.py:2515
msgid ""
"Either use the Token PIN , use the Userstore Password or use no fixed "
"password component."
msgstr ""
"ໃຊ້ Token PIN, ໃຊ້ລະຫັດຜ່ານ Userstore ຫຼື ບໍ່ໃຊ້ສ່ວນປະກອບລະຫັດຜ່ານຄົງທີ່."

#: lib/policy.py:2520
msgid ""
"Specify the list of token types, that must be used with challenge "
"response."
msgstr "ລະບຸລາຍການປະເພດໂທເຄັນ ທີ່ຕ້ອງຖືກໃຊ້ກັບ challenge response."

#: lib/policy.py:2528
msgid ""
"Use an alternative challenge text for telling the user to enter an OTP "
"value. You can also use tags for automated replacement. Check out the "
"documentation for more details."
msgstr ""
"ໃຊ້ຂໍ້ຄວາມແຊລເລນຈ໌ທາງເລືອກເພື່ອບອກຜູ້ໃຊ້ໃຫ້ປ້ອນຄ່າ OTP. ທ່ານຍັງສາມາດໃຊ້ແທັກເພື່ອການແທນທີ່ແບບອັດຕະໂນ"
"ມັດໄດ້. ກວດສອບເອກະສານສຳລັບລາຍລະອຽດເພີ່ມເຕີມ."

#: lib/policy.py:2535
msgid ""
"If there are several different challenges, this text precedes the list of"
" the challenge texts."
msgstr ""
"ຖ້າມີແຊລເລນຈ໌ທີ່ແຕກຕ່າງກັນຫຼາຍຢ່າງ, ຂໍ້ຄວາມນີ້ຈະຢູ່ໜ້າລາຍການຂອງຂໍ້ຄວາມແຊລເລນຈ໌."

#: lib/policy.py:2540
msgid ""
"If there are several different challenges, this text follows the list of "
"the challenge texts."
msgstr ""
"ຖ້າມີແຊລເລນຈ໌ທີ່ແຕກຕ່າງກັນຫຼາຍຢ່າງ, ຂໍ້ຄວາມນີ້ຈະຢູ່ຫຼັງລາຍການຂອງຂໍ້ຄວາມແຊລເລນຈ໌."

#: lib/policy.py:2545
msgid ""
"If the PIN of a token is to be changed, this will allow the user to "
"change the PIN during a validate/check request via challenge / response."
msgstr ""
"ຖ້າ PIN ຂອງໂທເຄັນຈະຖືກປ່ຽນ, ສິ່ງນີ້ຈະອະນຸຍາດໃຫ້ຜູ້ໃຊ້ປ່ຽນ PIN ໃນລະຫວ່າງຄຳຮ້ອງຂໍ validate/"
"check ຜ່ານ challenge / response."

#: lib/policy.py:2550
msgid "Specify the list of token types, that can not be used for authentication."
msgstr "ລະບຸລາຍການປະເພດໂທເຄັນ ທີ່ບໍ່ສາມາດໃຊ້ໃນການຢືນຢັນຕົວຕົນ."

#: lib/policy.py:2557
msgid ""
"The autoresync of a token can be done via a challenge response "
"message.You need to activate 'Automatic resync' in the general settings!"
msgstr ""
"ການຣີຊິ້ງອັດຕະໂນມັດຂອງໂທເຄັນສາມາດເຮັດໄດ້ຜ່ານຂໍ້ຄວາມ challenge response. ທ່ານຈຳເປັນຕ້ອງເປີດໃ"
"ຊ້ 'Automatic resync' ໃນການຕັ້ງຄ່າທົ່ວໄປ!"

#: lib/policy.py:2562
msgid ""
"In case of a successful authentication the following token or container "
"type is enrolled. The maximum number of tokens for a user is checked."
msgstr ""
"ໃນກໍລະນີທີ່ການຢືນຢັນຕົວຕົນສຳເລັດ, ໂທເຄັນ ຫຼື ປະເພດຄອນເທນເນີຕໍ່ໄປນີ້ຈະຖືກລົງທະບຽນ. ຈຳນວນໂທເຄັນສູງສຸດ"
"ສຳລັບຜູ້ໃຊ້ຈະຖືກກວດສອບ."

#: lib/policy.py:2568
msgid "Change the default text that is shown during enrolling a token."
msgstr "ປ່ຽນຂໍ້ຄວາມເລີ່ມຕົ້ນທີ່ສະແດງໃນລະຫວ່າງການລົງທະບຽນໂທເຄັນ."

#: lib/policy.py:2573
msgid ""
"Select the template to use for the enrollment of a smartphone container "
"via multichallenge."
msgstr ""
"ເລືອກເທມເພລດທີ່ຈະໃຊ້ສຳລັບການລົງທະບຽນຄອນເທນເນີສະມາດໂຟນຜ່ານ multichallenge."

#: lib/policy.py:2579
msgid ""
"If enabled, the user can choose to skip enrollment of the token during "
"authentication. If disabled, the user must enroll a token. This is also "
"the default behavior."
msgstr ""
"ຖ້າເປີດໃຊ້, ຜູ້ໃຊ້ສາມາດເລືອກຂ້າມການລົງທະບຽນໂທເຄັນໃນລະຫວ່າງການຢືນຢັນຕົວຕົນໄດ້. ຖ້າປິດໃຊ້, ຜູ້ໃຊ້ຕ້ອງລົ"
"ງທະບຽນໂທເຄັນ. ນີ້ຍັງເປັນພຶດຕິກຳເລີ່ມຕົ້ນອີກດ້ວຍ."

#: lib/policy.py:2584
msgid ""
"If enabled, a successful registration with the enroll_via_multichallenge "
"action for passkeys will directly mark the token for offline use and send"
" the offline data."
msgstr ""
"ຖ້າເປີດໃຊ້, ການລົງທະບຽນທີ່ສຳເລັດດ້ວຍການປະຕິບັດງານ enroll_via_multichallenge ສຳລັບແພສຄີ ຈະ"
"ໝາຍໂທເຄັນສຳລັບການໃຊ້ງານອອບໄລນ໌ໂດຍກົງ ແລະ ສົ່ງຂໍ້ມູນອອບໄລນ໌."

#: lib/policy.py:2590
msgid ""
"If set, the user in this realm will be authenticated against the "
"userstore or against the given RADIUS config, if the user has no tokens "
"assigned."
msgstr ""
"ຖ້າຕັ້ງໄວ້, ຜູ້ໃຊ້ໃນເຣມນີ້ຈະຖືກຢືນຢັນຕົວຕົນທຽບກັບ userstore ຫຼື ທຽບກັບການຕັ້ງຄ່າ RADIUS ທີ່ໃຫ້ມາ, ຖ້າຜູ້"
"ໃຊ້ບໍ່ມີໂທເຄັນມອບໝາຍ."

#: lib/policy.py:2597
msgid ""
"This allows to automatically assign a Token within privacyIDEA, if the "
"user was authenticated via passthru against a RADIUS server. The OTP "
"value is used to find the unassigned token in privacyIDEA. Enter the "
"length of the OTP value and where the PIN is set like 8:pin or pin:6."
msgstr ""
"ສິ່ງນີ້ອະນຸຍາດໃຫ້ມອບໝາຍໂທເຄັນໂດຍອັດຕະໂນມັດພາຍໃນ privacyIDEA, ຖ້າຜູ້ໃຊ້ຖືກຢືນຢັນຕົວຕົນຜ່ານ "
"passthru ທຽບກັບເຊີບເວີ RADIUS. ຄ່າ OTP ຖືກໃຊ້ເພື່ອຊອກຫາໂທເຄັນທີ່ບໍ່ໄດ້ມອບໝາຍໃນ "
"privacyIDEA. ປ້ອນຄວາມຍາວຂອງຄ່າ OTP ແລະ ບ່ອນທີ່ຕັ້ງ PIN ເຊັ່ນ 8:pin ຫຼື pin:6."

#: lib/policy.py:2604
msgid ""
"If the user has no token, the authentication request for this user will "
"always be true."
msgstr ""
"ຖ້າຜູ້ໃຊ້ບໍ່ມີໂທເຄັນ, ຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນສຳລັບຜູ້ໃຊ້ນີ້ຈະເປັນຈິງສະເໝີ."

#: lib/policy.py:2609
msgid ""
"If the user user does not exist, the authentication request for this non-"
"existing user will always be true."
msgstr ""
"ຖ້າຜູ້ໃຊ້ບໍ່ມີຢູ່, ຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນສຳລັບຜູ້ໃຊ້ທີ່ບໍ່ມີຢູ່ນີ້ຈະເປັນຈິງສະເໝີ."

#: lib/policy.py:2615
msgid ""
"Can be used to modify the parameters pass, user and realm in an "
"authentication request. See the documentation for an example."
msgstr ""
"ສາມາດໃຊ້ເພື່ອດັດແກ້ພາຣາມິເຕີ pass, user ແລະ realm ໃນຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນ. ເບິ່ງເອກະສານສຳລັ"
"ບຕົວຢ່າງ."

#: lib/policy.py:2622
msgid ""
"In authentication requests, sets or overwrites the realm parameter. It "
"takes precedence over the mangle and setrealm policies."
msgstr ""
"ໃນຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນ, ຈະຕັ້ງຄ່າ ຫຼື ຂຽນທັບພາຣາມິເຕີ realm. ມັນມີຄວາມສຳຄັນເໜືອກວ່ານະໂຍບາຍ "
"mangle ແລະ setrealm."

#: lib/policy.py:2627
msgid ""
"If a user authenticates successfully reset the failcounter of all of his "
"tokens."
msgstr ""
"ຖ້າຜູ້ໃຊ້ຢືນຢັນຕົວຕົນສຳເລັດ ໃຫ້ຣີເຊັດ failcounter ຂອງໂທເຄັນທັງໝົດຂອງລາວ."

#: lib/policy.py:2632
msgid ""
"Increase the failcounter for all the tokens, for which a challenge has "
"been triggered."
msgstr "ເພີ່ມ failcounter ສຳລັບໂທເຄັນທັງໝົດທີ່ຖືກກະຕຸ້ນແຊລເລນຈ໌."

#: lib/policy.py:2636
msgid ""
"Cache the password used for authentication and allow authentication with "
"the same credentials for a certain amount of time. Specify timeout like "
"4h or 4h/5m."
msgstr ""
"ແຄຊລະຫັດຜ່ານທີ່ໃຊ້ສຳລັບການຢືນຢັນຕົວຕົນ ແລະ ອະນຸຍາດໃຫ້ຢືນຢັນຕົວຕົນດ້ວຍຂໍ້ມູນດຽວກັນເປັນເວລາໃດໜຶ່ງ. ລະບຸເ"
"ວລາໝົດອາຍຸເຊັ່ນ 4h ຫຼື 4h/5m."

#: lib/policy.py:2643
msgid ""
"You can set the client modes in the order that you prefer. For example: "
"\"interactive webauthn poll u2f\". Accepted values are: <code>interactive"
" webauthn poll u2f</code>"
msgstr ""
"ທ່ານສາມາດຕັ້ງຄ່າຮູບແບບໄຄລ໌ເອັນຕາມລຳດັບທີ່ທ່ານຕ້ອງການ. ຕົວຢ່າງ: \"interactive webauthn poll "
"u2f\". ຄ່າທີ່ຍອມຮັບໄດ້ຄື: <code>interactive webauthn poll u2f</code>"

#: lib/policy.py:2649
msgid ""
"When enabled, authentication attempts will be interpreted as either the "
"PIN or the answer to a challenge. PIN concatenated with OTP can not be "
"used anymore! Does only work when authenticating with a username."
msgstr ""
"ເມື່ອເປີດໃຊ້, ຄວາມພະຍາຍາມໃນການຢືນຢັນຕົວຕົນຈະຖືກຕີຄວາມໝາຍວ່າເປັນ PIN ຫຼື ຄຳຕອບຂອງແຊລເລນຈ໌. "
"PIN ທີ່ເຊື່ອມກັບ OTP ຈະບໍ່ສາມາດໃຊ້ໄດ້ອີກຕໍ່ໄປ! ໃຊ້ໄດ້ສະເພາະເມື່ອຢືນຢັນຕົວຕົນດ້ວຍຊື່ຜູ້ໃຊ້."

#: lib/policy.py:2655
msgid ""
"Store the last used token type per user and application in the custom "
"user attributes. For the next authentication the last used token type is "
"used to identify the preferred client mode."
msgstr ""
"ຈັດເກັບປະເພດໂທເຄັນທີ່ໃຊ້ຫຼ້າສຸດຕໍ່ຜູ້ໃຊ້ ແລະ ແອັບພລິເຄຊັນໃນແອັດທຣີບິວຜູ້ໃຊ້ແບບກຳນົດເອງ. ສຳລັບການຢືນຢັນຕົວ"
"ຕົນຄັ້ງຕໍ່ໄປ ປະເພດໂທເຄັນທີ່ໃຊ້ຫຼ້າສຸດຈະຖືກໃຊ້ເພື່ອລະບຸຮູບແບບໄຄລ໌ເອັນທີ່ຕ້ອງການ."

#: lib/policy.py:2661
msgid "Enable to return an unspecific error message for failed authentications."
msgstr ""
"ເປີດໃຊ້ເພື່ອສົ່ງກັບຂໍ້ຄວາມສະແດງຂໍ້ຜິດພາດແບບບໍ່ສະເພາະເຈາະຈົງສຳລັບການຢືນຢັນຕົວຕົນທີ່ລົ້ມເຫຼວ."

#: lib/policy.py:2667
#, python-brace-format
msgid ""
"Allow the user to authenticate (default). If set to '{0!s}', the "
"authentication of the user will be denied."
msgstr ""
"ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ຢືນຢັນຕົວຕົນ (ເລີ່ມຕົ້ນ). ຖ້າຕັ້ງເປັນ '{0!s}', ການຢືນຢັນຕົວຕົນຂອງຜູ້ໃຊ້ຈະຖືກປະຕິເສດ."

#: lib/policy.py:2674
msgid ""
"Allow the application to choose which token types should be used for "
"authentication. Application may set the parameter 'type' in the request. "
"Works with validate/check, validate/samlcheck and "
"validate/triggerchallenge."
msgstr ""
"ອະນຸຍາດໃຫ້ແອັບພລິເຄຊັນເລືອກປະເພດໂທເຄັນທີ່ຈະໃຊ້ສຳລັບການຢືນຢັນຕົວຕົນ. ແອັບພລິເຄຊັນອາດຈະຕັ້ງພາຣາມິເຕີ "
"'type' ໃນຄຳຮ້ອງຂໍ. ໃຊ້ງານໄດ້ກັບ validate/check, validate/samlcheck ແລະ validate/"
"triggerchallenge."

#: lib/policy.py:2681
msgid ""
"You can specify how many successful authentication requests a user is "
"allowed to do in a given time. Specify like 1/5s, 2/10m, 10/1h - s, m, h "
"being second, minute and hour."
msgstr ""
"ທ່ານສາມາດລະບຸຈຳນວນຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນທີ່ສຳເລັດທີ່ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເຮັດໃນເວລາທີ່ກຳນົດ. ລະບຸເຊັ່"
"ນ 1/5s, 2/10m, 10/1h - s, m, h ແມ່ນວິນາທີ, ນາທີ ແລະ ຊົ່ວໂມງ."

#: lib/policy.py:2689
msgid ""
"You can specify how many failed authentication requests a user is allowed"
" to do in a given time. Specify like 1/5s, 2/10m, 10/1h - s, m, h being "
"second, minute and hour."
msgstr ""
"ທ່ານສາມາດລະບຸຈຳນວນຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົນທີ່ລົ້ມເຫຼວທີ່ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ເຮັດໃນເວລາທີ່ກຳນົດ. ລະບຸເຊັ່"
"ນ 1/5s, 2/10m, 10/1h - s, m, h ແມ່ນວິນາທີ, ນາທີ ແລະ ຊົ່ວໂມງ."

#: lib/policy.py:2697
msgid ""
"You can specify in which time frame the user needs to authenticate again "
"with this token. If the user authenticates later, authentication will "
"fail. Specify like 30h, 7d or 1y."
msgstr ""
"ທ່ານສາມາດລະບຸຂອບເວລາທີ່ຜູ້ໃຊ້ຈຳເປັນຕ້ອງຢືນຢັນຕົວຕົນອີກຄັ້ງດ້ວຍໂທເຄັນນີ້. ຖ້າຜູ້ໃຊ້ຢືນຢັນຕົວຕົນພາຍຫຼັງ, ການຢື"
"ນຢັນຕົວຕົນຈະລົ້ມເຫຼວ. ລະບຸເຊັ່ນ 30h, 7d ຫຼື 1y."

#: lib/policy.py:2705
msgid "The user will only be authenticated with this very tokentype."
msgstr "ຜູ້ໃຊ້ຈະຖືກຢືນຢັນຕົວຕົນດ້ວຍປະເພດໂທເຄັນນີ້ເທົ່ານັ້ນ."

#: lib/policy.py:2712
msgid ""
"The user will only be authenticated if the serial number of the token "
"matches this regexp."
msgstr "ຜູ້ໃຊ້ຈະຖືກຢືນຢັນຕົວຕົນກໍຕໍ່ເມື່ອເລກຊີຣຽນຂອງໂທເຄັນກົງກັບ regexp ນີ້."

#: lib/policy.py:2718
msgid ""
"The user will only be authenticated if the tokeninfo field matches the "
"regexp (key/&lt;regexp&gt;/)."
msgstr ""
"ຜູ້ໃຊ້ຈະຖືກຢືນຢັນຕົວຕົນກໍຕໍ່ເມື່ອຟິວ tokeninfo ກົງກັບ regexp (key/&lt;regexp&gt;/)."

#: lib/policy.py:2725
msgid ""
"The Realm of the user is set to this very realm. This is important if the"
" user is not contained in the default realm and can not pass his realm."
msgstr ""
"ເຣມຂອງຜູ້ໃຊ້ຖືກຕັ້ງເປັນເຣມນີ້. ສິ່ງນີ້ສຳຄັນຖ້າຜູ້ໃຊ້ບໍ່ໄດ້ຢູ່ໃນເຣມເລີ່ມຕົ້ນ ແລະ ບໍ່ສາມາດສົ່ງເຣມຂອງຕົນເອງໄດ້."

#: lib/policy.py:2732
msgid ""
"In case of successful authentication additional no detail information "
"will be returned."
msgstr "ໃນກໍລະນີທີ່ການຢືນຢັນຕົວຕົນສຳເລັດ ຈະບໍ່ມີຂໍ້ມູນລະອຽດເພີ່ມເຕີມຖືກສົ່ງກັບ."

#: lib/policy.py:2739
msgid ""
"In case of failed authentication additional no detail information will be"
" returned."
msgstr ""
"ໃນກໍລະນີທີ່ການຢືນຢັນຕົວຕົນລົ້ມເຫຼວ ຈະບໍ່ມີຂໍ້ມູນລະອຽດເພີ່ມເຕີມຖືກສົ່ງກັບ."

#: lib/policy.py:2746
msgid ""
"In case of successful authentication user data will be added in the "
"detail branch of the authentication response."
msgstr ""
"ໃນກໍລະນີທີ່ການຢືນຢັນຕົວຕົນສຳເລັດ ຂໍ້ມູນຜູ້ໃຊ້ຈະຖືກເພີ່ມໃນສາຂາລາຍລະອຽດຂອງຄຳຕອບການຢືນຢັນຕົວຕົນ."

#: lib/policy.py:2753
msgid ""
"In case of successful authentication the user resolver and realm will be "
"added in the detail branch of the authentication response."
msgstr ""
"ໃນກໍລະນີທີ່ການຢືນຢັນຕົວຕົນສຳເລັດ ຣີຊອລເວີຜູ້ໃຊ້ ແລະ ເຣມຈະຖືກເພີ່ມໃນສາຂາລາຍລະອຽດຂອງຄຳຕອບການຢືນຢັນ"
"ຕົວຕົນ."

#: lib/policy.py:2760
msgid ""
"The sending of an API Auth Key is required during authentication. This "
"avoids rogue authenticate requests against the /validate/check interface."
msgstr ""
"ການສົ່ງ API Auth Key ແມ່ນຈຳເປັນໃນລະຫວ່າງການຢືນຢັນຕົວຕົນ. ສິ່ງນີ້ຈະຊ່ວຍຫຼີກເວັ້ນຄຳຮ້ອງຂໍການຢືນຢັນຕົວຕົ"
"ນທີ່ບໍ່ຕ້ອງການຕໍ່ອິນເຕີເຟດ /validate/check."

#: lib/policy.py:2767
msgid ""
"If set, the /healthz/resolversz endpoint requires a valid admin "
"authentication token to include the status of each resolver individually."
msgstr ""
"ຖ້າຕັ້ງໄວ້, ເອັນພອຍ /healthz/resolversz ຕ້ອງການໂທເຄັນການຢືນຢັນຕົວຕົນຂອງຜູ້ດູແລລະບົບທີ່ຖືກຕ້ອງ ເພື່"
"ອລວມສະຖານະຂອງແຕ່ລະຣີຊອລເວີແຍກກັນ."

#: lib/policy.py:2775
msgid ""
"If set, administrators will see a dashboard as start screen when logging "
"in to privacyIDEA WebUI."
msgstr ""
"ຖ້າຕັ້ງໄວ້, ຜູ້ດູແລລະບົບຈະເຫັນແດຊບອດເປັນໜ້າຈໍເລີ່ມຕົ້ນເມື່ອເຂົ້າສູ່ລະບົບ privacyIDEA WebUI."

#: lib/policy.py:2781
msgid ""
"If set to \"privacyIDEA\" the users and admins need to authenticate "
"against privacyIDEA when they log in to the Web UI. Defaults to "
"\"userstore\"."
msgstr ""
"ຖ້າຕັ້ງເປັນ \"privacyIDEA\" ຜູ້ໃຊ້ ແລະ ຜູ້ດູແລລະບົບຈະຕ້ອງຢືນຢັນຕົວຕົນກັບ privacyIDEA ເມື່ອເຂົ້າສູ່ລະ"
"ບົບ Web UI. ຄ່າເລີ່ມຕົ້ນແມ່ນ \"userstore\"."

#: lib/policy.py:2789
msgid ""
"An alternative text to display on the WebUI login dialog instead of "
"\"Please sign in\"."
msgstr ""
"ຂໍ້ຄວາມທາງເລືອກເພື່ອສະແດງໃນໄດອາລອກເຂົ້າສູ່ລະບົບ WebUI ແທນ \"Please sign in\"."

#: lib/policy.py:2793
msgid ""
"When searching in the user list, the search will only performed when "
"pressing enter."
msgstr "ເມື່ອຄົ້ນຫາໃນລາຍຊື່ຜູ້ໃຊ້, ການຄົ້ນຫາຈະດຳເນີນການກໍຕໍ່ເມື່ອກົດປຸ່ມ Enter."

#: lib/policy.py:2798
msgid ""
"The action taken when a user is idle beyond the logout_time limit. "
"Defaults to \"lockscreen\"."
msgstr ""
"ການກະທຳທີ່ເກີດຂຶ້ນເມື່ອຜູ້ໃຊ້ບໍ່ເຄື່ອນໄຫວເກີນກຳນົດເວລາ logout_time. ຄ່າເລີ່ມຕົ້ນແມ່ນ "
"\"lockscreen\"."

#: lib/policy.py:2806
msgid ""
"The REMOTE_USER set by the webserver can be used to login to privacyIDEA "
"or it will be ignored. Defaults to \"disable\"."
msgstr ""
"REMOTE_USER ທີ່ຕັ້ງໂດຍເວັບເຊີບເວີສາມາດຖືກໃຊ້ເພື່ອເຂົ້າສູ່ລະບົບ privacyIDEA ຫຼື ມັນຈະຖືກລະເລີຍ. ຄ່າເ"
"ລີ່ມຕົ້ນແມ່ນ \"disable\"."

#: lib/policy.py:2812
msgid ""
"Set the time in seconds after which the user will be logged out from the "
"WebUI. Default: 120"
msgstr "ຕັ້ງເວລາເປັນວິນາທີທີ່ຜູ້ໃຊ້ຈະຖືກອອກຈາກລະບົບ WebUI. ເລີ່ມຕົ້ນ: 120"

#: lib/policy.py:2817
msgid ""
"privacyIDEA issues a JWT when the user or admins logs in to the WebUI. "
"The default validity is 1 hour. You can specify different validity times "
"in seconds."
msgstr ""
"privacyIDEA ອອກ JWT ເມື່ອຜູ້ໃຊ້ ຫຼື ຜູ້ດູແລລະບົບເຂົ້າສູ່ລະບົບ WebUI. ຄວາມຖືກຕ້ອງເລີ່ມຕົ້ນແມ່ນ 1 ຊົ່ວໂມ"
"ງ. ທ່ານສາມາດລະບຸເວລາຄວາມຖືກຕ້ອງທີ່ແຕກຕ່າງກັນເປັນວິນາທີ."

#: lib/policy.py:2822
msgid "Set how many tokens should be displayed in the token view on one page."
msgstr "ຕັ້ງຄ່າຈຳນວນໂທເຄັນທີ່ຈະສະແດງໃນມຸມມອງໂທເຄັນໃນໜຶ່ງໜ້າ."

#: lib/policy.py:2827
msgid "Set how many users should be displayed in the user view on one page."
msgstr "ຕັ້ງຄ່າຈຳນວນຜູ້ໃຊ້ທີ່ຈະສະແດງໃນມຸມມອງຜູ້ໃຊ້ໃນໜຶ່ງໜ້າ."

#: lib/policy.py:2832
msgid ""
"Set how many audit entries should be displayed in the audit view on one "
"page."
msgstr "ຕັ້ງຄ່າຈຳນວນລາຍການກວດສອບທີ່ຈະສະແດງໃນມຸມມອງການກວດສອບໃນໜຶ່ງໜ້າ."

#: lib/policy.py:2837
msgid "Use your own html template for the web UI menu."
msgstr "ໃຊ້ເທມເພລດ html ຂອງທ່ານເອງສຳລັບເມນູ web UI."

#: lib/policy.py:2841
msgid "Use your own html template for the web UI baseline/footer."
msgstr "ໃຊ້ເທມເພລດ html ຂອງທ່ານເອງສຳລັບ baseline/footer ຂອງ web UI."

#: lib/policy.py:2845
msgid "Link your privacy statement to be displayed in the baseline/footer."
msgstr "ເຊື່ອມຕໍ່ໃບປະກາດຄວາມເປັນສ່ວນຕົວຂອງທ່ານເພື່ອສະແດງໃນ baseline/footer."

#: lib/policy.py:2849
msgid ""
"Whether the user ID and the resolver should be displayed in the token "
"list."
msgstr "ບໍ່ວ່າ ID ຜູ້ໃຊ້ ແລະ ຣີຊອລເວີຄວນຈະຖືກສະແດງໃນລາຍຊື່ໂທເຄັນຫຼືບໍ່."

#: lib/policy.py:2854
msgid ""
"The URL of a repository, where the policy templates can be found.  "
"(Default /static/policy-templates/"
msgstr ""
"URL ຂອງຣີພອສິທໍຣີ, ບ່ອນທີ່ສາມາດພົບເທມເພລດນະໂຍບາຍໄດ້. (ເລີ່ມຕົ້ນ /static/policy-templates/"

#: lib/policy.py:2860
msgid ""
"The URL of an SSO provider for redirect at logout.(The URL must start "
"with http:// or https://)"
msgstr ""
"URL ຂອງຜູ້ໃຫ້ບໍລິການ SSO ສຳລັບການຣີໄດຣັກເມື່ອອອກຈາກລະບົບ. (URL ຕ້ອງຂຶ້ນຕົ້ນດ້ວຍ http:// ຫຼື "
"https://)"

#: lib/policy.py:2865
msgid "As long as a user has no token, he will only see a token wizard in the UI."
msgstr "ຕາບໃດທີ່ຜູ້ໃຊ້ບໍ່ມີໂທເຄັນ, ລາວຈະເຫັນພຽງແຕ່ຕົວຊ່ວຍໂທເຄັນໃນ UI."

#: lib/policy.py:2871
msgid ""
"The tokenwizard will be displayed in the token menu, even if the user "
"already has a token."
msgstr ""
"ຕົວຊ່ວຍໂທເຄັນຈະຖືກສະແດງໃນເມນູໂທເຄັນ, ເຖິງແມ່ນວ່າຜູ້ໃຊ້ຈະມີໂທເຄັນແລ້ວກໍຕາມ."

#: lib/policy.py:2877
msgid ""
"This is a whitespace separated list of tokentypes, for which a rollover "
"button is displayed in the token details."
msgstr ""
"ນີ້ແມ່ນລາຍການປະເພດໂທເຄັນທີ່ແຍກດ້ວຍຊ່ອງຫວ່າງ, ເຊິ່ງຈະມີປຸ່ມໂຣລໂອເວີສະແດງໃນລາຍລະອຽດໂທເຄັນ."

#: lib/policy.py:2884
msgid "The welcome dialog will be displayed if the user has no tokens assigned."
msgstr "ໄດອາລອກຕ້ອນຮັບຈະຖືກສະແດງຖ້າຜູ້ໃຊ້ບໍ່ມີໂທເຄັນມອບໝາຍ."

#: lib/policy.py:2888
msgid "This is the default token type in the token enrollment dialog."
msgstr "ນີ້ແມ່ນປະເພດໂທເຄັນເລີ່ມຕົ້ນໃນໄດອາລອກການລົງທະບຽນໂທເຄັນ."

#: lib/policy.py:2894
msgid "This is the default container type in the container create dialog."
msgstr "ນີ້ແມ່ນປະເພດຄອນເທນເນີເລີ່ມຕົ້ນໃນໄດອາລອກສ້າງຄອນເທນເນີ."

#: lib/policy.py:2899
msgid ""
"A list of realm names, which are displayed in a drop down menu in the "
"WebUI login screen. Realms are separated by white spaces."
msgstr ""
"ລາຍຊື່ຊື່ເຣມ, ເຊິ່ງຈະຖືກສະແດງໃນເມນູແບບເລື່ອນລົງໃນໜ້າຈໍເຂົ້າສູ່ລະບົບ WebUI. ເຣມຖືກແຍກດ້ວຍຊ່ອງຫວ່າງ."

#: lib/policy.py:2905
msgid ""
"If this is checked, the administrator will not see the welcome dialog "
"anymore."
msgstr "ຖ້າເລືອກອັນນີ້, ຜູ້ດູແລລະບົບຈະບໍ່ເຫັນໄດອາລອກຕ້ອນຮັບອີກຕໍ່ໄປ."

#: lib/policy.py:2910
msgid ""
"Per default disabled actions result in disabled buttons. When checking "
"this action, buttons of disabled actions are hidden."
msgstr ""
"ໂດຍເລີ່ມຕົ້ນ ການກະທຳທີ່ຖືກປິດໃຊ້ງານຈະສົ່ງຜົນໃຫ້ປຸ່ມຖືກປິດໃຊ້ງານ. ເມື່ອເລືອກການກະທຳນີ້, ປຸ່ມຂອງການກະທຳທີ່"
"ຖືກປິດໃຊ້ງານຈະຖືກຊ່ອນໄວ້."

#: lib/policy.py:2915
msgid ""
"If this is checked, there will be a confirmation prompt when deleting "
"policies, events, mresolver, resolver or periodic tasks!"
msgstr ""
"ຖ້າເລືອກອັນນີ້, ຈະມີການເຕືອນໃຫ້ຢືນຢັນເມື່ອລຶບນະໂຍບາຍ, ເຫດການ, mresolver, ຣີຊອລເວີ ຫຼື ວຽກງານຕາ"
"ມກຳນົດເວລາ!"

#: lib/policy.py:2920
msgid "If this is checked, the seed will be displayed as text during enrollment."
msgstr ""
"ຖ້າເລືອກອັນນີ້, ເມັດພັນ (seed) ຈະຖືກສະແດງເປັນຂໍ້ຄວາມໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/policy.py:2925
msgid ""
"If this is checked, the privacyIDEA Node name will be displayed in the "
"menu bar."
msgstr "ຖ້າເລືອກອັນນີ້, ຊື່ privacyIDEA Node ຈະຖືກສະແດງໃນແຖບເມນູ."

#: lib/policy.py:2930
msgid ""
"If this is checked, the enrollment page for HOTP, TOTP and Push tokens "
"will contain a QR code that leads to the privacyIDEA Authenticator in the"
" Google Play Store."
msgstr ""
"ຖ້າເລືອກອັນນີ້, ໜ້າການລົງທະບຽນສຳລັບໂທເຄັນ HOTP, TOTP ແລະ Push ຈະມີ QR ໂຄດທີ່ນຳໄປສູ່ "
"privacyIDEA Authenticator ໃນ Google Play Store."

#: lib/policy.py:2937
msgid ""
"If this is checked, the enrollment page for HOTP, TOTP and Push tokens "
"will contain a QR code that leads to the privacyIDEA Authenticator in the"
" iOS App Store."
msgstr ""
"ຖ້າເລືອກອັນນີ້, ໜ້າການລົງທະບຽນສຳລັບໂທເຄັນ HOTP, TOTP ແລະ Push ຈະມີ QR ໂຄດທີ່ນຳໄປສູ່ "
"privacyIDEA Authenticator ໃນ iOS App Store."

#: lib/policy.py:2944
msgid ""
"This action adds a QR code in the enrollment page for HOTP, TOTP and Push"
" tokens, that lead to this given URL."
msgstr ""
"ການກະທຳນີ້ເພີ່ມ QR ໂຄດໃນໜ້າການລົງທະບຽນສຳລັບໂທເຄັນ HOTP, TOTP ແລະ Push, ເຊິ່ງນຳໄປສູ່ URL ທີ່"
"ໃຫ້ມານີ້."

#: lib/policy.py:2949
msgid ""
"The RSS feeds fetched for the user defined in the format: "
"<code>'Title':'URL'-'Title':'URL'</code> "
msgstr ""
"RSS feeds ທີ່ດຶງຂໍ້ມູນສຳລັບຜູ້ໃຊ້ທີ່ກຳນົດໄວ້ໃນຟໍແມັດ: <code>'Title':'URL'-'Title':'URL'</"
"code> "

#: lib/policy.py:2953
msgid ""
"The age of the RSS feed entries in days. Use <code>0</code> to hide the "
"news feed. For admins the default is 180 days and for users 0 days."
msgstr ""
"ອາຍຸຂອງລາຍການ RSS feed ເປັນວັນ. ໃຊ້ <code>0</code> ເພື່ອຊ່ອນ news feed. ສຳລັບຜູ້ດູແລລະບົບ"
"ຄ່າເລີ່ມຕົ້ນແມ່ນ 180 ວັນ ແລະ ສຳລັບຜູ້ໃຊ້ແມ່ນ 0 ວັນ."

#: lib/policy.py:2958
msgid ""
"Container type to be created with the container wizard. It is required to"
" set at least this option to enable the container wizard. As long as the "
"user has no container assigned he will only see the container wizard in "
"the UI."
msgstr ""
"ປະເພດຄອນເທນເນີທີ່ຈະສ້າງດ້ວຍຕົວຊ່ວຍຄອນເທນເນີ. ມັນຈຳເປັນຕ້ອງຕັ້ງຄ່າທາງເລືອກນີ້ຢ່າງໜ້ອຍເພື່ອເປີດໃຊ້ຕົວຊ່ວ"
"ຍຄອນເທນເນີ. ຕາບໃດທີ່ຜູ້ໃຊ້ບໍ່ມີຄອນເທນເນີມອບໝາຍ, ລາວຈະເຫັນພຽງແຕ່ຕົວຊ່ວຍຄອນເທນເນີໃນ UI."

#: lib/policy.py:2965
msgid ""
"Name of the container template to be used to create a container in the "
"container wizard (optional). Note that the template must be of the same "
"type as selected in the container_wizard_type."
msgstr ""
"ຊື່ຂອງເທມເພລດຄອນເທນເນີທີ່ຈະໃຊ້ສ້າງຄອນເທນເນີໃນຕົວຊ່ວຍຄອນເທນເນີ (ທາງເລືອກ). ໝາຍເຫດວ່າເທມເພລດ"
"ຕ້ອງເປັນປະເພດດຽວກັນກັບທີ່ເລືອກໃນ container_wizard_type."

#: lib/policy.py:2972
msgid ""
"In the container wizard, a QR code will be generated to register the new "
"container on the smartphone. (Only applicable for smartphone containers)"
msgstr ""
"ໃນຕົວຊ່ວຍຄອນເທນເນີ, QR ໂຄດຈະຖືກສ້າງຂຶ້ນເພື່ອລົງທະບຽນຄອນເທນເນີໃໝ່ໃນສະມາດໂຟນ. (ໃຊ້ໄດ້ກັບຄອນເທນ"
"ເນີສະມາດໂຟນເທົ່ານັ້ນ)"

#: lib/policy.py:2978
msgid "Show or hide the passkey login button on the login screen."
msgstr "ສະແດງ ຫຼື ຊ່ອນປຸ່ມເຂົ້າສູ່ລະບົບແພສຄີໃນໜ້າຈໍເຂົ້າສູ່ລະບົບ."

#: lib/policy.py:2984
msgid ""
"The URL of your privacyIDEA server, e.g. <code>https://pi/</code>. It is "
"used to build URLs the container can contact for registration and "
"synchronization."
msgstr ""
"URL ຂອງເຊີບເວີ privacyIDEA ຂອງທ່ານ, ເຊັ່ນ <code>https://pi/</code>. ມັນຖືກໃຊ້ເພື່ອສ້າງ "
"URL ທີ່ຄອນເທນເນີສາມາດຕິດຕໍ່ໄດ້ສຳລັບການລົງທະບຽນ ແລະ ການຣີຊິ້ງ."

#: lib/policy.py:2990
msgid ""
"The time in minutes the client has to do the second step of the "
"registration. The default is ten minutes."
msgstr ""
"ເວລາເປັນນາທີທີ່ໄຄລ໌ເອັນມີເພື່ອເຮັດຂັ້ນຕອນທີສອງຂອງການລົງທະບຽນ. ເລີ່ມຕົ້ນແມ່ນສິບນາທີ."

#: lib/policy.py:2996
msgid ""
"After the client (a registered container) has challenged an action such "
"as synchronization or unregistration, this defines the time in minutes "
"the client has to complete the action. The default is two minutes."
msgstr ""
"ຫຼັງຈາກໄຄລ໌ເອັນ (ຄອນເທນເນີທີ່ລົງທະບຽນແລ້ວ) ໄດ້ກະຕຸ້ນແຊລເລນຈ໌ການກະທຳ ເຊັ່ນ: ການຣີຊິ້ງ ຫຼື ການຍົກເລີກ"
"ການລົງທະບຽນ, ສິ່ງນີ້ຈະກຳນົດເວລາເປັນນາທີທີ່ໄຄລ໌ເອັນຕ້ອງເຮັດການກະທຳໃຫ້ສຳເລັດ. ເລີ່ມຕົ້ນແມ່ນສອງນາທີ."

#: lib/policy.py:3005
msgid ""
"The container needs to verify the SSL certificate of the privacyIDEA "
"server during registration and synchronization. (default True)"
msgstr ""
"ຄອນເທນເນີຈຳເປັນຕ້ອງຢືນຢັນ SSL ໃບຢັ້ງຢືນຂອງເຊີບເວີ privacyIDEA ໃນລະຫວ່າງການລົງທະບຽນ ແລະ ກາ"
"ນຣີຊິ້ງ. (ເລີ່ມຕົ້ນ True)"

#: lib/policy.py:3012
msgid ""
"The client is allowed to perform a rollover of the container and the "
"included tokens."
msgstr ""
"ໄຄລ໌ເອັນໄດ້ຮັບອະນຸຍາດໃຫ້ດຳເນີນການໂຣລໂອເວີຂອງຄອນເທນເນີ ແລະ ໂທເຄັນທີ່ບັນຈຸຢູ່."

#: lib/policy.py:3017
msgid ""
"During the first synchronization, the server automatically adds the "
"clients tokens existing in privacyIDEA to the container. This allows to "
"register devices with existing tokens as container without having to "
"manually add the tokens on the device to the container."
msgstr ""
"ໃນລະຫວ່າງການຣີຊິ້ງຄັ້ງທຳອິດ, ເຊີບເວີຈະເພີ່ມໂທເຄັນໄຄລ໌ເອັນທີ່ມີຢູ່ໃນ privacyIDEA ໃສ່ຄອນເທນເນີໂດຍອັດຕ"
