#: api/lib/prepolicy.py:2877
msgid ""
"Authentication failure. The account has exceeded the authentication time "
"limit!"
msgstr "ການຢືນຢັນຕົວຕົນຜິດພາດ. ບັນຊີນີ້ໄດ້ເກີນກຳນົດເວລາຢືນຢັນຕົວຕົນແລ້ວ!"

#: api/lib/utils.py:402
msgid "Authentication failure. Missing Authorization header."
msgstr "ການຢືນຢັນຕົວຕົນຜິດພາດ. ບໍ່ມີ Authorization header."

#: api/lib/utils.py:407 api/lib/utils.py:438
msgid "Authentication failure. Error decoding the Authorization token:"
msgstr "ການຢືນຢັນຕົວຕົນຜິດພາດ. ເກີດຂໍ້ຜິດພາດໃນການຖອດລະຫັດໂທເຄັນ Authorization:"

#: api/lib/utils.py:431 api/lib/utils.py:441
msgid "Authentication failure. Your token has expired:"
msgstr "ການຢືນຢັນຕົວຕົນຜິດພາດ. ໂທເຄັນຂອງທ່ານໝົດອາຍຸແລ້ວ:"

#: api/lib/utils.py:444
#, python-brace-format
msgid ""
"Authentication failure. The username {wrong_username} is not allowed to "
"impersonate via JWT."
msgstr ""
"ການຢືນຢັນຕົວຕົນຜິດພາດ. ຊື່ຜູ້ໃຊ້ {wrong_username} ບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ສວມຮອຍຜ່ານ JWT."

#: api/lib/utils.py:449
#, python-brace-format
msgid ""
"Authentication failure. You do not have the necessary role "
"({required_role}) to access this resource!"
msgstr ""
"ການຢືນຢັນຕົວຕົນຜິດພາດ. ທ່ານບໍ່ມີບົດບາດ ({required_role}) ທີ່ຈຳເປັນເພື່ອເຂົ້າເຖິງຊັບພະຍາກອນນີ້!"

#: api/lib/utils.py:466
msgid "Invalid policy name:"
msgstr "ຊື່ນະໂຍບາຍບໍ່ຖືກຕ້ອງ:"

#: api/lib/utils.py:469
msgid "The name of the policy may only contain the characters a-zA-Z0-9_. -"
msgstr "ຊື່ຂອງນະໂຍບາຍຄວນມີພຽງແຕ່ຕົວອັກສອນ a-zA-Z0-9_. -"

#: lib/challengeresponsedecorators.py:150
msgid "Please enter the new PIN again"
msgstr "ກະລຸນາປ້ອນ PIN ໃໝ່ອີກຄັ້ງ"

#: lib/challengeresponsedecorators.py:164
msgid "Please enter a new PIN"
msgstr "ກະລຸນາປ້ອນ PIN ໃໝ່"

#: lib/challengeresponsedecorators.py:202
msgid "To resync your token, please enter the next OTP value"
msgstr "ເພື່ອຣີຊິ້ງໂທເຄັນຂອງທ່ານ, ກະລຸນາປ້ອນຄ່າ OTP ຖັດໄປ"

#: lib/containerclass.py:919
msgid "General purpose container that can hold any type and any number of token."
msgstr "ຄອນເທນເນີອະເນກປະສົງທີ່ສາມາດບັນຈຸໂທເຄັນໄດ້ທຸກປະເພດ ແລະ ທຸກຈຳນວນ."

#: lib/decorators.py:44 lib/token.py:2526
msgid "This action is not possible, since the token is locked"
msgstr "ການກະທຳນີ້ເປັນໄປບໍ່ໄດ້, ເນື່ອງຈາກໂທເຄັນຖືກລັອກໄວ້"

#: lib/decorators.py:87
msgid "You either need to provide user or serial"
msgstr "ທ່ານຈຳເປັນຕ້ອງລະບຸຜູ້ໃຊ້ ຫຼື ເລກຊີຣຽນ"

#: lib/decorators.py:116
msgid "You need to specify a serial, user or credential_id."
msgstr "ທ່ານຕ້ອງລະບຸເລກຊີຣຽນ, ຜູ້ໃຊ້ ຫຼື credential_id."

#: lib/decorators.py:118
msgid "Invalid serial number."
msgstr "ເລກຊີຣຽນບໍ່ຖືກຕ້ອງ."

#: lib/decorators.py:120
msgid "Invalid user."
msgstr "ຜູ້ໃຊ້ບໍ່ຖືກຕ້ອງ."

#: lib/policy.py:218
msgid ""
"Note: If you use a comma in the message, you need to escape it with a "
"backslash."
msgstr ""
"ໝາຍເຫດ: ຖ້າທ່ານໃຊ້ເຄື່ອງໝາຍຈຸດໃນຂໍ້ຄວາມ, ທ່ານຕ້ອງໃຊ້ backslash ເພື່ອເຣັດມັນ."

#: lib/policy.py:1227
msgid "Policy does not exist:"
msgstr "ນະໂຍບາຍບໍ່ມີຢູ່:"

#: lib/policy.py:1230
msgid "Policy already exists:"
msgstr "ນະໂຍບາຍມີຢູ່ແລ້ວ:"

#: lib/policy.py:1396
msgid "Invalid client definition!"
msgstr "ຄຳນິຍາມໄຄລ໌ເອັນບໍ່ຖືກຕ້ອງ!"

#: lib/policy.py:1649
msgid "Define in which resolver the user should be registered."
msgstr "ກຳນົດວ່າຜູ້ໃຊ້ຄວນລົງທະບຽນໃນຣີຊອລເວີໃດ."

#: lib/policy.py:1653
msgid "Define in which realm the user should be registered."
msgstr "ກຳນົດວ່າຜູ້ໃຊ້ຄວນລົງທະບຽນໃນເຣມໃດ."

#: lib/policy.py:1657
msgid ""
"The SMTP server configuration, that should be used to send the "
"registration email."
msgstr "ການຕັ້ງຄ່າເຊີບເວີ SMTP ທີ່ຄວນໃຊ້ເພື່ອສົ່ງອີເມວລົງທະບຽນ."

#: lib/policy.py:1661
msgid ""
"Only users with this email address are allowed to register. This is a "
"regular expression."
msgstr ""
"ມີພຽງຜູ້ໃຊ້ທີ່ມີທີ່ຢູອີເມວນີ້ເທົ່ານັ້ນທີ່ໄດ້ຮັບອະນຸຍາດໃຫ້ລົງທະບຽນ. ນີ້ແມ່ນເຣກູລ້າເອກສ໌ເພຣສຊັນ (regular "
"expression)."

#: lib/policy.py:1666
#, python-brace-format
msgid ""
"The body of the registration email. Use '{regkey}' as tag for the "
"registration key."
msgstr "ເນື້ອຫາຂອງອີເມວລົງທະບຽນ. ໃຊ້ '{regkey}' ເປັນແທັກສຳລັບຄີລົງທະບຽນ."

#: lib/policy.py:1670
msgid "Enable to return an unspecific error message for failed registrations."
msgstr ""
"ເປີດໃຊ້ເພື່ອສົ່ງກັບຂໍ້ຄວາມສະແດງຂໍ້ຜິດພາດແບບບໍ່ສະເພາະເຈາະຈົງສຳລັບການລົງທະບຽນທີ່ລົ້ມເຫຼວ."

#: lib/policy.py:1676
msgid "Admin is allowed to enable tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ເປີດໃຊ້ງານໂທເຄັນ."

#: lib/policy.py:1680
msgid "Admin is allowed to disable tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ປິດໃຊ້ງານໂທເຄັນ."

#: lib/policy.py:1685
msgid "Admin is allowed to set token properties."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງຄ່າຄຸນສົມບັດຂອງໂທເຄັນ."

#: lib/policy.py:1689
msgid "The admin is allowed to set the token description."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງຄຳອະທິບາຍໂທເຄັນ."

#: lib/policy.py:1694
msgid "Admin is allowed to set the OTP PIN of tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ຂອງໂທເຄັນ."

#: lib/policy.py:1699
msgid "Admin is allowed to set a random OTP PIN of tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ແບບສຸ່ມຂອງໂທເຄັນ."

#: lib/policy.py:1703
msgid "Admin is allowed to manually set and delete token info."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງຄ່າ ແລະ ລຶບຂໍ້ມູນໂທເຄັນດ້ວຍຕົນເອງ."

#: lib/policy.py:1707
msgid "Admin is allowed to set the OTP PIN during enrollment."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕັ້ງ OTP PIN ໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/policy.py:1712
msgid "Admin is allowed to resync tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຣີຊິ້ງໂທເຄັນ."

#: lib/policy.py:1717
msgid "Admin is allowed to reset the Failcounter of a token."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຣີເຊັດ Failcounter ຂອງໂທເຄັນ."

#: lib/policy.py:1722
msgid "Admin is allowed to revoke a token"
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຖອນຄືນໂທເຄັນ"

#: lib/policy.py:1727
msgid "Admin is allowed to assign a token to a user."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ມອບໝາຍໂທເຄັນໃຫ້ຜູ້ໃຊ້."

#: lib/policy.py:1733
msgid "Admin is allowed to remove the token from a user, i.e. unassign a token."
msgstr ""
"ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ເອົາໂທເຄັນອອກຈາກຜູ້ໃຊ້, ເຊັ່ນ: ຍົກເລີກການມອບໝາຍໂທເຄັນ."

#: lib/policy.py:1739
msgid "Admin is allowed to import token files."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ນຳເຂົ້າໄຟລ໌ໂທເຄັນ."

#: lib/policy.py:1744
msgid "Admin is allowed to remove tokens from the database."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບໂທເຄັນອອກຈາກຖານຂໍ້ມູນ."

#: lib/policy.py:1750
msgid "Admin is allowed to view the list of the users."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ເບິ່ງລາຍຊື່ຜູ້ໃຊ້."

#: lib/policy.py:1755
msgid "The Admin is allowed to list the machines."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ສະແດງລາຍຊື່ເຄື່ອງ."

#: lib/policy.py:1760
msgid "The Admin is allowed to attach and detach tokens to machines."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຕິດ ແລະ ປົດໂທເຄັນອອກຈາກເຄື່ອງ."

#: lib/policy.py:1767
msgid ""
"The Admin is allowed to fetch authentication items of tokens assigned to "
"machines."
msgstr ""
"ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ດຶງຂໍ້ມູນການຢືນຢັນຕົວຕົນຂອງໂທເຄັນທີ່ມອບໝາຍໃຫ້ກັບເຄື່ອງ."

#: lib/policy.py:1772
msgid "Admin is allowed to manage the realms of a token."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຈັດການເຣມຂອງໂທເຄັນ."

#: lib/policy.py:1777
msgid "Admin is allowed to list tokens."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ສະແດງລາຍຊື່ໂທເຄັນ."

#: lib/policy.py:1781
msgid "Admin is allowed to retrieve a serial for a given OTP value."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ດຶງເລກຊີຣຽນສຳລັບຄ່າ OTP ທີ່ໃຫ້ມາ."

#: lib/policy.py:1786
msgid "Admin is allowed to retrieve random keys from privacyIDEA."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ດຶງຄີສຸ່ມຈາກ privacyIDEA."

#: lib/policy.py:1791
msgid "Admin is allowed to copy the PIN of one token to another token."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຄັດລອກ PIN ຈາກໂທເຄັນໜຶ່ງໄປຫາອີກໂທເຄັນໜຶ່ງ."

#: lib/policy.py:1796
msgid ""
"Admin is allowed to copy the assigned user to another token, i.e. assign "
"a user to another token."
msgstr ""
"ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຄັດລອກຜູ້ໃຊ້ທີ່ມອບໝາຍໄວ້ໄປຫາໂທເຄັນອື່ນ, ເຊັ່ນ: ມອບໝາຍຜູ້ໃຊ້ໃຫ້ໂທເຄັນອື່ນ."

#: lib/policy.py:1801
msgid "Admin is allowed to trigger the lost token workflow."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ກະຕຸ້ນຂະບວນການເຮັດວຽກຂອງໂທເຄັນທີ່ເສຍຫາຍ."

#: lib/policy.py:1807
msgid "Admin is allowed to write and modify the system configuration."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນ ແລະ ດັດແກ້ການຕັ້ງຄ່າລະບົບ."

#: lib/policy.py:1812
msgid "Admin is allowed to delete keys in the system configuration."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບຄີໃນການຕັ້ງຄ່າລະບົບ."

#: lib/policy.py:1818
msgid "Admin is allowed to read basic system configuration."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານການຕັ້ງຄ່າລະບົບພື້ນຖານ."

#: lib/policy.py:1823
msgid ""
"Admin is allowed to export a documentation of the complete configuration "
"including resolvers and realm."
msgstr ""
"ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ສົ່ງອອກເອກະສານການຕັ້ງຄ່າທັງໝົດລວມທັງຣີຊອລເວີ ແລະ ເຣມ."

#: lib/policy.py:1831
msgid "Admin is allowed to write and modify the policies."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນ ແລະ ດັດແກ້ນະໂຍບາຍ."

#: lib/policy.py:1836
msgid "Admin is allowed to delete policies."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບນະໂຍບາຍ."

#: lib/policy.py:1841
msgid "Admin is allowed to read policies."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານນະໂຍບາຍ."

#: lib/policy.py:1845
msgid "Admin is allowed to write and modify the resolver and realm configuration."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນ ແລະ ດັດແກ້ການຕັ້ງຄ່າຣີຊອລເວີ ແລະ ເຣມ."

#: lib/policy.py:1852
msgid "Admin is allowed to delete resolvers and realms."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບຣີຊອລເວີ ແລະ ເຣມ."

#: lib/policy.py:1857
msgid "Admin is allowed to read resolvers."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານຣີຊອລເວີ."

#: lib/policy.py:1861
msgid ""
"Admin is allowed to create new CA Connector definitions and modify "
"existing ones."
msgstr ""
"ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ສ້າງຄຳນິຍາມ CA Connector ໃໝ່ ແລະ ດັດແກ້ທີ່ມີຢູ່."

#: lib/policy.py:1867
msgid "Admin is allowed to delete CA Connector definitions."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບຄຳນິຍາມ CA Connector."

#: lib/policy.py:1872
msgid "Admin is allowed to read CA Connector definitions."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານຄຳນິຍາມ CA Connector."

#: lib/policy.py:1877
msgid "Admin is allowed to write and modify the machine resolvers."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນ ແລະ ດັດແກ້ຣີຊອລເວີເຄື່ອງ."

#: lib/policy.py:1883
msgid "Admin is allowed to delete machine resolvers."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ລຶບຣີຊອລເວີເຄື່ອງ."

#: lib/policy.py:1889
msgid "Admin is allowed to read machine resolvers."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານຣີຊອລເວີເຄື່ອງ."

#: lib/policy.py:1896 lib/policy.py:2241
msgid "Set the maximum allowed length of the OTP PIN."
msgstr "ຕັ້ງຄ່າຄວາມຍາວສູງສຸດທີ່ອະນຸຍາດຂອງ OTP PIN."

#: lib/policy.py:1901 lib/policy.py:2245
msgid "Set the minimum required length of the OTP PIN."
msgstr "ຕັ້ງຄ່າຄວາມຍາວຂັ້ນຕໍ່າທີ່ຕ້ອງການຂອງ OTP PIN."

#: lib/policy.py:1905 lib/policy.py:2249
msgid ""
"Specify the required contents of the OTP PIN. (c)haracters, (n)umeric, "
"(s)pecial. Use modifiers +/- or a list of allowed characters [1234567890]"
msgstr ""
"ລະບຸເນື້ອຫາທີ່ຕ້ອງການຂອງ OTP PIN. (c)haracters, (n)umeric, (s)pecial. ໃຊ້ຕົວດັດແປງ "
"+/- ຫຼື ລາຍການຕົວອັກສອນທີ່ອະນຸຍາດ [1234567890]"

#: lib/policy.py:1914
msgid "The length of a random PIN set by the administrator."
msgstr "ຄວາມຍາວຂອງ PIN ແບບສຸ່ມທີ່ຕັ້ງໂດຍຜູ້ດູແລລະບົບ."

#: lib/policy.py:1917
msgid "Admin is allowed to view the Audit log."
msgstr "ຜູ້ດູແລລະບົບໄດ້ຮັບອະນຸຍາດໃຫ້ເບິ່ງບັນທຶກການກວດສອບ (Audit log)."

#: lib/policy.py:1921
