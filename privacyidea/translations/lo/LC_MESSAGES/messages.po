#: lib/tokens/smstoken.py:196
msgid "SMS Token"
msgstr "ໂທເຄັນ SMS"

#: lib/tokens/smstoken.py:198
msgid "SMS: Send a One Time Password to the users mobile phone."
msgstr "SMS: ສົ່ງລະຫັດຜ່ານໃຊ້ຄັ້ງດຽວໄປຍັງໂທລະສັບມືຖືຂອງຜູ້ໃຊ້."

#: lib/tokens/smstoken.py:207
#, python-brace-format
