#: lib/eventhandler/requestmangler.py:87
msgid "The parameter that should be deleted."
msgstr "ພາຣາມິເຕີທີ່ຄວນລຶບອອກ."

#: lib/eventhandler/requestmangler.py:93
msgid "The parameter that should be added or modified."
msgstr "ພາຣາມິເຕີທີ່ຄວນເພີ່ມ ຫຼື ແກ້ໄຂ."

#: lib/eventhandler/requestmangler.py:98
#, python-brace-format
msgid ""
"The new value of the parameter. Can contain tags like {0}, {1} for the "
"matched sub strings."
msgstr ""
"ຄ່າໃໝ່ຂອງພາຣາມິເຕີ. ສາມາດບັນຈຸແທັກເຊັ່ນ {0}, {1} ສຳລັບສະຕຣິງຍ່ອຍທີ່ກົງກັນ."

#: lib/eventhandler/requestmangler.py:103
msgid "The parameter, that should match some values."
msgstr "ພາຣາມິເຕີ, ທີ່ຄວນກົງກັບບາງຄ່າ."

#: lib/eventhandler/requestmangler.py:107
msgid ""
"The value of the match_parameter. It can contain a regular expression and"
" '()' to transfer values to the new parameter."
msgstr ""
"ຄ່າຂອງ match_parameter. ມັນສາມາດບັນຈຸນິພົດປົກກະຕິ ແລະ '()' ເພື່ອໂອນຄ່າໄປຍັງພາຣາມິເຕີໃໝ່."

#: lib/eventhandler/requestmangler.py:112
msgid ""
"If the parameter is 'username', 'user' or 'realm', the user will be "
"reset. This can have an effect on any further actions on the user!"
msgstr ""
"ຖ້າພາຣາມິເຕີແມ່ນ 'username', 'user' ຫຼື 'realm', ຜູ້ໃຊ້ຈະຖືກຣີເຊັດ. ສິ່ງນີ້ສາມາດມີຜົນກະທົບຕໍ່ການກະ"
"ທຳໃດໆຕໍ່ໄປກ່ຽວກັບຜູ້ໃຊ້ນີ້!"

#: lib/eventhandler/responsemangler.py:79
msgid ""
"The JSON pointer (key) that should be deleted. Please specify in the "
"format '/detail/message'."
msgstr "JSON pointer (ຄີ) ທີ່ຄວນລຶບອອກ. ກະລຸນາລະບຸໃນຮູບແບບ '/detail/message'."

#: lib/eventhandler/responsemangler.py:86
msgid ""
"The JSON pointer (key) that should be set. Please specify in the format "
"'/detail/message'."
msgstr "JSON pointer (ຄີ) ທີ່ຄວນຕັ້ງຄ່າ. ກະລຸນາລະບຸໃນຮູບແບບ '/detail/message'."

#: lib/eventhandler/responsemangler.py:92
msgid "The type of the value."
msgstr "ປະເພດຂອງຄ່າ."

#: lib/eventhandler/responsemangler.py:98
msgid "The value of the JSON key that should be set."
msgstr "ຄ່າຂອງຄີ JSON ທີ່ຄວນຕັ້ງ."

#: lib/eventhandler/scripthandler.py:92
#: lib/smsprovider/ScriptSMSProvider.py:121
msgid ""
"Wait for script to complete or run script in background. This will either"
" return the HTTP request early or could also block the request."
msgstr ""
"ລໍຖ້າໃຫ້ສະຄຣິບເຮັດວຽກສຳເລັດ ຫຼື ຣັນສະຄຣິບໃນພື້ນຫຼັງ. ສິ່ງນີ້ຈະສົ່ງຄືນຄຳຮ້ອງຂໍ HTTP ໂດຍໄວ ຫຼື ອາດຈະຂັດຂວ"
"າງຄຳຮ້ອງຂໍກໍໄດ້."

#: lib/eventhandler/scripthandler.py:100
msgid "On script error raise exception in HTTP request."
msgstr "ເມື່ອສະຄຣິບຜິດພາດ ໃຫ້ຍົກຂໍ້ຍົກເວັ້ນ (exception) ໃນຄຳຮ້ອງຂໍ HTTP."

#: lib/eventhandler/scripthandler.py:104
msgid ""
"Finish current transaction before running the script. This is useful if "
"changes to the database should be made available to the script or the "
"running request."
msgstr ""
"ສຳເລັດທຸລະກຳປັດຈຸບັນກ່ອນທີ່ຈະຣັນສະຄຣິບ. ສິ່ງນີ້ມີປະໂຫຍດຖ້າການປ່ຽນແປງໃນຖານຂໍ້ມູນຄວນຖືກເຮັດໃຫ້ສະຄຣິບ ຫຼື "
"ຄຳຮ້ອງຂໍທີ່ກຳລັງເຮັດວຽກຢູ່ສາມາດນຳໃຊ້ໄດ້."

#: lib/eventhandler/scripthandler.py:111
msgid "Add '--serial <serial number>' as script parameter."
msgstr "ເພີ່ມ '--serial <serial number>' ເປັນພາຣາມິເຕີຂອງສະຄຣິບ."

#: lib/eventhandler/scripthandler.py:116
msgid "Add '--user <username>' as script parameter."
msgstr "ເພີ່ມ '--user <username>' ເປັນພາຣາມິເຕີຂອງສະຄຣິບ."

#: lib/eventhandler/scripthandler.py:121
msgid "Add '--realm <realm>' as script parameter."
msgstr "ເພີ່ມ '--realm <realm>' ເປັນພາຣາມິເຕີຂອງສະຄຣິບ."

#: lib/eventhandler/scripthandler.py:126
msgid ""
"Add the username of the logged in user as script parameter like '--"
"logged_in_user <username>'."
msgstr ""
"ເພີ່ມຊື່ຜູ້ໃຊ້ຂອງຜູ້ໃຊ້ທີ່ເຂົ້າສູ່ລະບົບເປັນພາຣາມິເຕີຂອງສະຄຣິບເຊັ່ນ '--logged_in_user <username>'."

#: lib/eventhandler/scripthandler.py:132
msgid ""
"Add the role (either admin or user) of the logged in user as script "
"parameter like '--logged_in_role <role>'."
msgstr ""
"ເພີ່ມບົດບາດ (admin ຫຼື user) ຂອງຜູ້ໃຊ້ທີ່ເຂົ້າສູ່ລະບົບເປັນພາຣາມິເຕີຂອງສະຄຣິບເຊັ່ນ '--"
"logged_in_role <role>'."

#: lib/eventhandler/tokenhandler.py:144
msgid "set a new realm of the token"
msgstr "ຕັ້ງຄ່າເລມໃໝ່ຂອງໂທເຄັນ"

#: lib/eventhandler/tokenhandler.py:150
msgid ""
"The new realm will be the only realm of the token. I.e. all other realms "
"will be removed from this token. If disabled, the realm will be added to "
"the token."
msgstr ""
"ເລມໃໝ່ຈະເປັນເລມດຽວຂອງໂທເຄັນ. ກໍຄືເລມອື່ນທັງໝົດຈະຖືກລຶບອອກຈາກໂທເຄັນນີ້. ຖ້າປິດໃຊ້ງານ, ເລມຈະຖືກເພີ່"
"ມເຂົ້າໃນໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:167
msgid "set the PIN of the token to a random PIN of this length."
msgstr "ຕັ້ງຄ່າ PIN ຂອງໂທເຄັນໃຫ້ເປັນ PIN ແບບສຸ່ມທີ່ມີຄວາມຍາວເທົ່ານີ້."

#: lib/eventhandler/tokenhandler.py:177
msgid "Token type to create"
msgstr "ປະເພດໂທເຄັນທີ່ຈະສ້າງ"

#: lib/eventhandler/tokenhandler.py:183
msgid "Assign token to user in request or to tokenowner."
msgstr "ມອບໝາຍໂທເຄັນໃຫ້ຜູ້ໃຊ້ໃນຄຳຮ້ອງຂໍ ຫຼື ໃຫ້ເຈົ້າຂອງໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:190
msgid "Set the realm of the newly created token."
msgstr "ຕັ້ງຄ່າເລມຂອງໂທເຄັນທີ່ສ້າງຂຶ້ນໃໝ່."

#: lib/eventhandler/tokenhandler.py:199
msgid "Dynamically read the mobile number from the user store."
msgstr "ອ່ານເບີມືຖືຈາກບ່ອນເກັບຂໍ້ມູນຜູ້ໃຊ້ແບບໄດນາມິກ."

#: lib/eventhandler/tokenhandler.py:207
msgid "Dynamically read the email address from the user store."
msgstr "ອ່ານທີ່ຢູ່ອີເມວຈາກບ່ອນເກັບຂໍ້ມູນຜູ້ໃຊ້ແບບໄດນາມິກ."

#: lib/eventhandler/tokenhandler.py:215
msgid "Use a specific SMTP server configuration for this token."
msgstr "ໃຊ້ການຕັ້ງຄ່າເຊີບເວີ SMTP ສະເພາະສຳລັບໂທເຄັນນີ້."

#: lib/eventhandler/tokenhandler.py:223
msgid "Use a specific SMS gateway configuration for this token."
msgstr "ໃຊ້ການຕັ້ງຄ່າປະຕູ SMS ສະເພາະສຳລັບໂທເຄັນນີ້."

#: lib/eventhandler/tokenhandler.py:229
msgid "A dictionary of additional init parameters."
msgstr "ວັດຈະນານຸກົມຂອງພາຣາມິເຕີເລີ່ມຕົ້ນເພີ່ມເຕີມ."

#: lib/eventhandler/tokenhandler.py:236
msgid ""
"Set the MOTP PIN of the MOTP token during enrollment. This is a required "
"value for enrolling MOTP tokens."
msgstr ""
"ຕັ້ງຄ່າ MOTP PIN ຂອງໂທເຄັນ MOTP ໃນລະຫວ່າງການລົງທະບຽນ. ນີ້ແມ່ນຄ່າທີ່ຈຳເປັນສຳລັບການລົງທະບຽນໂທເ"
"ຄັນ MOTP."

#: lib/eventhandler/tokenhandler.py:244
msgid ""
"Add the token to the container if there is one identifiable in the "
"request."
msgstr "ເພີ່ມໂທເຄັນເຂົ້າໃນຄອນເທນເນີຖ້າມີອັນທີ່ລະບຸໄດ້ໃນຄຳຮ້ອງຂໍ."

#: lib/eventhandler/tokenhandler.py:252
msgid "The new description of the token."
msgstr "ຄຳອະທິບາຍໃໝ່ຂອງໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:261
msgid ""
"The token will be valid starting at the given date. Can be a fixed date "
"or an offset like +10m, +24h, +7d."
msgstr ""
"ໂທເຄັນຈະມີຜົນບັງຄັບໃຊ້ເລີ່ມແຕ່ວັນທີທີ່ກຳນົດ. ສາມາດເປັນວັນທີທີ່ແນ່ນອນ ຫຼື ໄລຍະເວລາຊົດເຊີຍເຊັ່ນ +10m, "
"+24h, +7d."

#: lib/eventhandler/tokenhandler.py:269
msgid ""
"The token will be valid until the given date. Can be a fixed date or an "
"offset like +10m, +24h, +7d."
msgstr ""
"ໂທເຄັນຈະມີຜົນບັງຄັບໃຊ້ຈົນຮອດວັນທີທີ່ກຳນົດ. ສາມາດເປັນວັນທີທີ່ແນ່ນອນ ຫຼື ໄລຍະເວລາຊົດເຊີຍເຊັ່ນ +10m, "
"+24h, +7d."

#: lib/eventhandler/tokenhandler.py:283
msgid "Set the new count window of the token."
msgstr "ຕັ້ງຄ່າໜ້າຕ່າງການນັບໃໝ່ຂອງໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:293
msgid "Set the failcounter of the token."
msgstr "ຕັ້ງຄ່າຕົວນັບຄວາມຜິດພາດຂອງໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:303
msgid ""
"Increase or decrease the fail counter of the token. Values of +n, -n with"
" n being an integer are accepted."
msgstr ""
"ເພີ່ມ ຫຼື ຫຼຸດຕົວນັບຄວາມຜິດພາດຂອງໂທເຄັນ. ຄ່າ +n, -n ໂດຍທີ່ n ເປັນຈຳນວນເຕັມແມ່ນໄດ້ຮັບການຍອມຮັບ."

#: lib/eventhandler/tokenhandler.py:313
msgid "Set the maximum failcounter of the token."
msgstr "ຕັ້ງຄ່າຕົວນັບຄວາມຜິດພາດສູງສຸດຂອງໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:322
msgid "Set this tokeninfo key."
msgstr "ຕັ້ງຄ່າຄີ tokeninfo ນີ້."

#: lib/eventhandler/tokenhandler.py:327
msgid "Set the above key to this value."
msgstr "ຕັ້ງຄ່າຄີຂ້າງເທິງໃຫ້ເປັນຄ່ານີ້."

#: lib/eventhandler/tokenhandler.py:337
msgid ""
"Interpret the tokeninfo as 'int' and increase the tokeninfo value by the "
"given offset."
msgstr ""
"ຕີຄວາມໝາຍ tokeninfo ເປັນ 'int' ແລະ ເພີ່ມຄ່າ tokeninfo ຕາມໄລຍະຊົດເຊີຍທີ່ກຳນົດ."

#: lib/eventhandler/tokenhandler.py:343
msgid ""
"The increment the tokeninfo key should be increased. Can be positive or "
"negative, s.th. like +1 or -7."
msgstr ""
"ການເພີ່ມຂຶ້ນທີ່ຄີ tokeninfo ຄວນໄດ້ຮັບ. ສາມາດເປັນຄ່າບວກ ຫຼື ລົບ, ເຊັ່ນ +1 ຫຼື -7."

#: lib/eventhandler/tokenhandler.py:353
msgid "Delete this tokeninfo key."
msgstr "ລຶບຄີ tokeninfo ນີ້ອອກ."

#: lib/eventhandler/tokenhandler.py:362
msgid "Add a tokengroup to the token."
msgstr "ເພີ່ມກຸ່ມໂທເຄັນ (tokengroup) ເຂົ້າໃນໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:372
msgid "Remove a tokengroup from the token."
msgstr "ເອົາກຸ່ມໂທເຄັນອອກຈາກໂທເຄັນ."

#: lib/eventhandler/tokenhandler.py:382
msgid "The ID of the machine you want to attach the token to"
msgstr "ID ຂອງເຄື່ອງທີ່ທ່ານຕ້ອງການຕິດໂທເຄັນໃສ່"

#: lib/eventhandler/tokenhandler.py:389
msgid "Set the service_id for an SSH application."
msgstr "ຕັ້ງຄ່າ service_id ສຳລັບແອັບພລິເຄຊັ່ນ SSH."

#: lib/eventhandler/tokenhandler.py:398
msgid ""
"Set a token application like 'offline' or 'SSH'. Note: Not all tokens "
"work well with all applications!"
msgstr ""
"ຕັ້ງຄ່າແອັບພລິເຄຊັ່ນໂທເຄັນເຊັ່ນ 'offline' ຫຼື 'SSH'. ໝາຍເຫດ: ບໍ່ແມ່ນທຸກໂທເຄັນຈະເຮັດວຽກໄດ້ດີກັບທຸກແອັ"
"ບພລິເຄຊັ່ນ!"

#: lib/eventhandler/tokenhandler.py:408
msgid "The number of offline OTP values available"
msgstr "ຈຳນວນຄ່າ OTP ແບບອອບລາຍທີ່ມີໃຫ້"

#: lib/eventhandler/tokenhandler.py:416
msgid "The number of rounds for password hashing"
msgstr "ຈຳນວນຮອບສຳລັບການແຮຊລະຫັດຜ່ານ"

#: lib/eventhandler/usernotification.py:147
msgid "Send notification email via this email server."
msgstr "ສົ່ງອີເມວແຈ້ງເຕືອນຜ່ານເຊີບເວີອີເມວນີ."

#: lib/eventhandler/usernotification.py:151
msgid "Either send email as plain text or HTML."
msgstr "ສົ່ງອີເມວເປັນຂໍ້ຄວາມທຳມະດາ ຫຼື HTML."

#: lib/eventhandler/usernotification.py:155
msgid "Send QR-Code image as an attachment (cid URL: token_image)"
msgstr "ສົ່ງຮູບພາບ QR-Code ເປັນໄຟລ໌ແນບ (cid URL: token_image)"

#: lib/eventhandler/usernotification.py:160
msgid "The subject of the mail that is sent."
msgstr "ຫົວຂໍ້ຂອງອີເມວທີ່ຖືກສົ່ງ."

#: lib/eventhandler/usernotification.py:164
msgid "The Reply-To header in the sent email."
msgstr "ສ່ວນຫົວ Reply-To ໃນອີເມວທີ່ສົ່ງ."

#: lib/eventhandler/usernotification.py:186
#: lib/eventhandler/usernotification.py:239
msgid "Any email address, to which the notification should be sent."
msgstr "ທີ່ຢູ່ອີເມວໃດກໍໄດ້, ທີ່ຄວນສົ່ງການແຈ້ງເຕືອນໄປຫາ."

#: lib/eventhandler/usernotification.py:193
#: lib/eventhandler/usernotification.py:200
#: lib/eventhandler/usernotification.py:246
#: lib/eventhandler/usernotification.py:253
msgid ""
"You can enter a user attribute here to use an email address other than "
"the default."
msgstr ""
"ທ່ານສາມາດໃສ່ຄຸນລັກສະນະຜູ້ໃຊ້ທີ່ນີ້ເພື່ອໃຊ້ທີ່ຢູ່ອີເມວອື່ນນອກເໜືອຈາກຄ່າເລີ່ມຕົ້ນ."

#: lib/eventhandler/usernotification.py:207
#, python-brace-format
msgid ""
"The template of the mail body that will be sent. It may contain the "
"following tags as specified in the documentation: <code>{admin}, {realm},"
" {action}, {serial}, {url}, {user}, {givenname}, {surname}, {username}, "
"{userrealm}, {tokentype}, {tokendescription}, {registrationcode}, "
"{recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, "
"{ua_string}, {pin}.</code>"
msgstr ""
"ແມ່ແບບຂອງເນື້ອຫາອີເມວທີ່ຈະຖືກສົ່ງ. ມັນອາດຈະບັນຈຸແທັກດັ່ງຕໍ່ໄປນີ້ຕາມທີ່ລະບຸໄວ້ໃນເອກະສານ: <code>"
"{admin}, {realm}, {action}, {serial}, {url}, {user}, {givenname}, {surname}, "
"{username}, {userrealm}, {tokentype}, {tokendescription}, {registrationcode}"
", {recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, {ua_string}, "
"{pin}.</code>"

#: lib/eventhandler/usernotification.py:218
#: lib/eventhandler/usernotification.py:277
msgid "Send notification to this user."
msgstr "ສົ່ງການແຈ້ງເຕືອນຫາຜູ້ໃຊ້ນີ້."

#: lib/eventhandler/usernotification.py:262
msgid "Send the user notification via a predefined SMS gateway."
msgstr "ສົ່ງການແຈ້ງເຕືອນຜູ້ໃຊ້ຜ່ານປະຕູ SMS ທີ່ກຳນົດໄວ້ລ່ວງໜ້າ."

#: lib/eventhandler/usernotification.py:267
#, python-brace-format
msgid ""
"The text template of the SMS. It may contain the following tags as "
"specified in the documentation: <code>{admin}, {realm}, {action}, "
"{serial}, {url}, {user}, {givenname}, {surname}, {username}, {userrealm},"
" {tokentype}, {tokendescription}, {registrationcode}, "
"{recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, "
"{ua_string}, {pin}.</code>"
msgstr ""
"ແມ່ແບບຂໍ້ຄວາມຂອງ SMS. ມັນອາດຈະບັນຈຸແທັກດັ່ງຕໍ່ໄປນີ້ຕາມທີ່ລະບຸໄວ້ໃນເອກະສານ: <code>{admin}, "
"{realm}, {action}, {serial}, {url}, {user}, {givenname}, {surname}, "
"{username}, {userrealm}, {tokentype}, {tokendescription}, {registrationcode}"
", {recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, {ua_string}, "
"{pin}.</code>"

#: lib/eventhandler/usernotification.py:284
#, python-brace-format
msgid ""
"This is the template content of the new file. It may contain the "
"following tags as specified in the documentation: <code>{admin}, {realm},"
" {action}, {serial}, {url}, {user}, {givenname}, {surname}, {username}, "
"{userrealm}, {tokentype}, {tokendescription}, {registrationcode}, "
"{recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, "
"{ua_string}, {pin}.</code>"
msgstr ""
"ນີ້ແມ່ນເນື້ອຫາແມ່ແບບຂອງໄຟລ໌ໃໝ່. ມັນອາດຈະບັນຈຸແທັກດັ່ງຕໍ່ໄປນີ້ຕາມທີ່ລະບຸໄວ້ໃນເອກະສານ: <code>{admin}"
", {realm}, {action}, {serial}, {url}, {user}, {givenname}, {surname}, "
"{username}, {userrealm}, {tokentype}, {tokendescription}, {registrationcode}"
", {recipient_givenname}, {recipient_surname}, {googleurl_value}, "
"{googleurl_img}, {pushurl_value}, {pushurl_img}, {container_url_value}, "
"{container_url_img}, {time}, {date}, {client_ip}, {ua_browser}, {ua_string}, "
"{pin}.</code>"

#: lib/eventhandler/usernotification.py:295
#, python-brace-format
msgid ""
"The filename of the notification. Existing files are overwritten. The "
"name can contain tags as specified in the documentation and can also "
"contain the tag {random}."
msgstr ""
"ຊື່ໄຟລ໌ຂອງການແຈ້ງເຕືອນ. ໄຟລ໌ທີ່ມີຢູ່ຈະຖືກຂຽນທັບ. ຊື່ສາມາດບັນຈຸແທັກຕາມທີ່ລະບຸໄວ້ໃນເອກະສານ ແລະ ຍັງສາມາ"
"ດບັນຈຸແທັກ {random} ໄດ້ນຳ."

#: lib/eventhandler/webhookeventhandler.py:93
msgid "The URL the WebHook is posted to"
msgstr "URL ທີ່ WebHook ຖືກໂພສໄປຫາ"

#: lib/eventhandler/webhookeventhandler.py:98
msgid ""
"The MIME type (Content-Type) used for the WebHook payload, for example "
"application/json or application/x-www-form-urlencoded"
msgstr ""
"ປະເພດ MIME (Content-Type) ທີ່ໃຊ້ສຳລັບ WebHook payload, ຕົວຢ່າງເຊັ່ນ application/json "
"ຫຼື application/x-www-form-urlencoded"

#: lib/eventhandler/webhookeventhandler.py:107
#, python-brace-format
msgid ""
"You can use the following placeholders: {logged_in_user}, {realm}, "
"{surname}, {token_owner}, {user_realm}, {token_serial}. However, tag "
"availability is depending on the endpoint."
msgstr ""
"ທ່ານສາມາດໃຊ້ຕົວແທນ (placeholder) ຕໍ່ໄປນີ້ໄດ້: {logged_in_user}, {realm}, {surname}, "
"{token_owner}, {user_realm}, {token_serial}. ແນວໃດກໍຕາມ, ຄວາມພ້ອມໃຊ້ຂອງແທັກແມ່ນຂຶ້ນຢູ່"
"ກັບປາຍທາງ (endpoint)."

#: lib/eventhandler/webhookeventhandler.py:114
msgid "The data posted in the WebHook"
msgstr "ຂໍ້ມູນທີ່ຖືກໂພສໃນ WebHook"

#: lib/machines/ldap.py:371
#, python-brace-format
msgid ""
"Your LDAP machine resolver configuration seems to be OK, {0!s} machine "
"objects found in {1:.4f}s."
msgstr ""
"ການຕັ້ງຄ່າຣີໂຊລເວີເຄື່ອງ LDAP ຂອງທ່ານເບິ່ງຄືວ່າປົກກະຕິ, ພົບວັດຖຸເຄື່ອງ {0!s} ອັນໃນ {1:.4f} ວິນາທີ."

#: lib/policies/conditions.py:97
msgid ""
"Raise an error if the data that is required to check the condition is not"
" available."
msgstr "ຍົກຂໍ້ຜິດພາດຖ້າຂໍ້ມູນທີ່ຈຳເປັນໃນການກວດສອບເງື່ອນໄຂບໍ່ມີໃຫ້."

#: lib/policies/conditions.py:102
msgid ""
"If the required data is not available, the condition is considered to be "
"true. Hence, the policy is applied."
msgstr ""
"ຖ້າຂໍ້ມູນທີ່ຈຳເປັນບໍ່ມີໃຫ້, ເງື່ອນໄຂຈະຖືກພິຈາລະນາວ່າເປັນຈິງ. ສະນັ້ນ, ນະໂຍບາຍຈະຖືກນຳໃຊ້."

#: lib/policies/conditions.py:108
msgid ""
"If the required data is not available, the condition is considered to be "
"false. Hence, the policy is not applied."
msgstr ""
"ຖ້າຂໍ້ມູນທີ່ຈຳເປັນບໍ່ມີໃຫ້, ເງື່ອນໄຂຈະຖືກພິຈາລະນາວ່າເປັນເທັດ. ສະນັ້ນ, ນະໂຍບາຍຈະບໍ່ຖືກນຳໃຊ້."

#: lib/resolvers/LDAPIdResolver.py:1284
#, python-brace-format
msgid ""
"Your LDAP config found {0!s} user objects in {2:.4f}s, but only {1!s} "
"with the specified uidtype."
msgstr ""
