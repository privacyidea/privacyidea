#: lib/tokens/emailtoken.py:159
msgid "EMail: Send a One Time Password to the users email address."
msgstr "ອີເມວ: ສົ່ງລະຫັດຜ່ານໃຊ້ຄັ້ງດຽວໄປຍັງທີ່ຢູ່ອີເມວຂອງຜູ້ໃຊ້."

#: lib/tokens/emailtoken.py:167
#, python-brace-format
msgid ""
"The text that will be sent via EMail for an EMail-token. Several tags "
"like {otp} and {serial} can be used as parameters. You may also specify a"
" filename as email template starting with \"file:\"."
msgstr ""
"ຂໍ້ຄວາມທີ່ຈະສົ່ງຜ່ານອີເມວສຳລັບໂທເຄັນອີເມວ. ແທັກຫຼາຍຢ່າງເຊັ່ນ {otp} ແລະ {serial} ສາມາດໃຊ້ເປັນພາຣ"
"າມິເຕີໄດ້. ທ່ານຍັງສາມາດລະບຸຊື່ໄຟລ໌ເປັນແມ່ແບບອີເມວໂດຍເລີ່ມຕົ້ນດ້ວຍ \"file:\"."

#: lib/tokens/emailtoken.py:176
#, python-brace-format
msgid ""
"The subject of the EMail for an EMail token. Use tags like {otp} and "
"{serial} as parameters."
msgstr ""
"ຫົວຂໍ້ຂອງອີເມວສຳລັບໂທເຄັນອີເມວ. ໃຊ້ແທັກເຊັ່ນ {otp} ແລະ {serial} ເປັນພາຣາມິເຕີ."

#: lib/tokens/emailtoken.py:181
msgid ""
"If set, a new EMail OTP will be sent after successful authentication with"
" one EMail OTP."
msgstr ""
"ຖ້າຕັ້ງຄ່າ, OTP ອີເມວໃໝ່ຈະຖືກສົ່ງຫຼັງຈາກການຢັ້ງຢືນຕົວຕົນສຳເລັດດ້ວຍ OTP ອີເມວອັນໜຶ່ງ."

#: lib/tokens/emailtoken.py:186
msgid ""
"Use an alternative challenge text for telling the user to enter the code "
"from the e-mail. You can also use tags for automated replacement. Check "
"out the documentation for more details."
msgstr ""
"ໃຊ້ຂໍ້ຄວາມທ້າທາຍທາງເລືອກເພື່ອບອກໃຫ້ຜູ້ໃຊ້ໃສ່ລະຫັດຈາກອີເມວ. ທ່ານຍັງສາມາດໃຊ້ແທັກເພື່ອການປ່ຽນແທນອັດຕະໂ"
"ນມັດໄດ້. ກວດສອບເອກະສານສຳລັບລາຍລະອຽດເພີ່ມເຕີມ."

#: lib/tokens/emailtoken.py:196
msgid "The user may only have this maximum number of email tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນອີເມວມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/emailtoken.py:201
msgid ""
"The user may only have this maximum number of active email tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນອີເມວທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/emailtoken.py:283
msgid "Enter the OTP from the Email"
msgstr "ໃສ່ OTP ຈາກອີເມວ"

#: lib/tokens/emailtoken.py:325
msgid "The PIN was correct, but the EMail could not be sent!"
msgstr "PIN ຖືກຕ້ອງ, ແຕ່ບໍ່ສາມາດສົ່ງອີເມວໄດ້!"

#: lib/tokens/emailtoken.py:563
msgid "Please enter your new email address!"
msgstr "ກະລຸນາໃສ່ທີ່ຢູ່ອີເມວໃໝ່ຂອງທ່ານ!"

#: lib/tokens/emailtoken.py:603
msgid "The email address is not valid!"
msgstr "ທີ່ຢູ່ອີເມວບໍ່ຖືກຕ້ອງ!"

#: lib/tokens/foureyestoken.py:131
msgid "4Eyes Token: Use tokens of two or more users to authenticate"
msgstr ""
"ໂທເຄັນ 4Eyes: ໃຊ້ໂທເຄັນຂອງຜູ້ໃຊ້ສອງຄົນ ຫຼື ຫຼາຍກວ່ານັ້ນເພື່ອຢັ້ງຢືນຕົວຕົນ"

#: lib/tokens/foureyestoken.py:142
msgid "The user may only have this maximum number of 4eyes tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ 4eyes ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/foureyestoken.py:147
msgid ""
"The user may only have this maximum number of active 4eyes tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ 4eyes ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/hotptoken.py:84
msgid "Please enter a valid OTP value of the new token."
msgstr "ກະລຸນາໃສ່ຄ່າ OTP ທີ່ຖືກຕ້ອງຂອງໂທເຄັນໃໝ່."

#: lib/tokens/hotptoken.py:97
msgid "Specify the hashing function to be used. Can be SHA1, SHA256 or SHA512."
msgstr "ລະບຸຟັງຊັ່ນການແຮຊທີ່ຈະໃຊ້. ສາມາດເປັນ SHA1, SHA256 ຫຼື SHA512."

#: lib/tokens/hotptoken.py:99
msgid "Specify the OTP length to be used. Can be 6 or 8 digits."
msgstr "ລະບຸຄວາມຍາວ OTP ທີ່ຈະໃຊ້. ສາມາດເປັນ 6 ຫຼື 8 ຕົວເລກ."

#: lib/tokens/hotptoken.py:100
msgid "Specify whether users are allowed or forced to use two-step enrollment."
msgstr "ລະບຸວ່າຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດ ຫຼື ຖືກບັງຄັບໃຫ້ໃຊ້ການລົງທະບຽນສອງຂັ້ນຕອນ."

#: lib/tokens/hotptoken.py:102
msgid "Specify whether admins are allowed or forced to use two-step enrollment."
msgstr ""
"ລະບຸວ່າຜູ້ບໍລິຫານໄດ້ຮັບອະນຸຍາດ ຫຼື ຖືກບັງຄັບໃຫ້ໃຊ້ການລົງທະບຽນສອງຂັ້ນຕອນ."

#: lib/tokens/hotptoken.py:139
msgid "HOTP: Event based One Time Passwords."
msgstr "HOTP: ລະຫັດຜ່ານໃຊ້ຄັ້ງດຽວຕາມເຫດການ."

#: lib/tokens/hotptoken.py:147
msgid "The user may only have this maximum number of HOTP tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ HOTP ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/hotptoken.py:152
msgid "The user may only have this maximum number of active HOTP tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ HOTP ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/hotptoken.py:157 lib/tokens/totptoken.py:150
msgid "The size of the OTP seed part contributed by the client (in bytes)"
msgstr "ຂະໜາດຂອງສ່ວນ OTP seed ທີ່ປະກອບສ່ວນໂດຍລູກຄ້າ (ເປັນໄບຕ໌)"

#: lib/tokens/hotptoken.py:162 lib/tokens/totptoken.py:153
msgid "The size of the OTP seed part contributed by the server (in bytes)"
msgstr "ຂະໜາດຂອງສ່ວນ OTP seed ທີ່ປະກອບສ່ວນໂດຍເຊີບເວີ (ເປັນໄບຕ໌)"

#: lib/tokens/hotptoken.py:167 lib/tokens/totptoken.py:156
msgid ""
"The difficulty factor used for the OTP seed generation (should be at "
"least 10000)"
msgstr "ປັດໄຈຄວາມຍາກທີ່ໃຊ້ສຳລັບການສ້າງ OTP seed (ຄວນເປັນຢ່າງໜ້ອຍ 10000)"

#: lib/tokens/hotptoken.py:291
msgid "URL for google Authenticator"
msgstr "URL ສຳລັບ google Authenticator"

#: lib/tokens/hotptoken.py:305
msgid "URL for OATH token"
msgstr "URL ສຳລັບໂທເຄັນ OATH"

#: lib/tokens/hotptoken.py:861
msgid "Please scan the QR code and enter the OTP value!"
msgstr "ກະລຸນາສະແກນ QR code ແລະ ໃສ່ຄ່າ OTP!"

#: lib/tokens/indexedsecrettoken.py:51
#, python-brace-format
msgid "Please enter the positions {0!s} from your secret."
msgstr "ກະລຸນາໃສ່ຕຳແໜ່ງ {0!s} ຈາກລະຫັດລັບຂອງທ່ານ."

#: lib/tokens/indexedsecrettoken.py:100
msgid "Indexed Secret Token"
msgstr "ໂທເຄັນລະຫັດລັບແບບດັດຊະນີ"

#: lib/tokens/indexedsecrettoken.py:102
msgid "IndexedSecret: Request certain positions of a shared secret from the user."
msgstr "IndexedSecret: ຮ້ອງຂໍຕຳແໜ່ງບາງຢ່າງຂອງລະຫັດລັບຮ່ວມຈາກຜູ້ໃຊ້."

#: lib/tokens/indexedsecrettoken.py:110
msgid ""
"Use an alternative challenge text for telling the user which positions of"
" the secret he should enter. You can also use tags for automated "
"replacement. Check out the documentation for more details."
msgstr ""
"ໃຊ້ຂໍ້ຄວາມທ້າທາຍທາງເລືອກເພື່ອບອກຜູ້ໃຊ້ວ່າຄວນໃສ່ຕຳແໜ່ງໃດຂອງລະຫັດລັບ. ທ່ານຍັງສາມາດໃຊ້ແທັກເພື່ອການປ່ຽນ"
"ແທນອັດຕະໂນມັດໄດ້. ກວດສອບເອກະສານສຳລັບລາຍລະອຽດເພີ່ມເຕີມ."

#: lib/tokens/indexedsecrettoken.py:118
msgid "Number of necessary positions to be answered by the user."
msgstr "ຈຳນວນຕຳແໜ່ງທີ່ຈຳເປັນຕ້ອງໄດ້ຮັບຄຳຕອບຈາກຜູ້ໃຊ້."

#: lib/tokens/indexedsecrettoken.py:125
msgid "Preset the enrollment with the value of the given attribute."
msgstr "ກຳນົດຄ່າການລົງທະບຽນລ່ວງໜ້າດ້ວຍຄ່າຂອງຄຸນລັກສະນະທີ່ກຳນົດ."

#: lib/tokens/indexedsecrettoken.py:132 lib/tokens/indexedsecrettoken.py:139
msgid "The attribute whose value should be force set during enrollment."
msgstr "ຄຸນລັກສະນະທີ່ມີຄ່າຄວນຖືກບັງຄັບໃຫ້ຕັ້ງໃນລະຫວ່າງການລົງທະບຽນ."

#: lib/tokens/indexedsecrettoken.py:146
msgid ""
"The user may only have this maximum number of indexed secret tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນລະຫັດລັບແບບດັດຊະນີມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/indexedsecrettoken.py:151
msgid ""
"The user may only have this maximum number of active indexed secret "
"tokens assigned."
msgstr ""
"ຜູ້ໃຊ້ອາດມີໂທເຄັນລະຫັດລັບແບບດັດຊະນີທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/motptoken.py:87
msgid "mOTP: Classical mobile One Time Passwords."
msgstr "mOTP: ລະຫັດຜ່ານໃຊ້ຄັ້ງດຽວຜ່ານມືຖືແບບຄລາສສິກ."

#: lib/tokens/motptoken.py:113
msgid "The user may only have this maximum number of mOTP tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ mOTP ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/motptoken.py:118
msgid "The user may only have this maximum number of active mOTP tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ mOTP ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/motptoken.py:160
msgid "URL for mOTP token"
msgstr "URL ສຳລັບໂທເຄັນ mOTP"

#: lib/tokens/ocratoken.py:90
msgid "OCRA: Enroll an OCRA token."
msgstr "OCRA: ລົງທະບຽນໂທເຄັນ OCRA."

#: lib/tokens/ocratoken.py:100
msgid "The user may only have this maximum number of OCRA tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ OCRA ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/ocratoken.py:105
msgid "The user may only have this maximum number of active OCRA tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ OCRA ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/papertoken.py:94
msgid "PPR: One Time Passwords printed on a sheet of paper."
msgstr "PPR: ລະຫັດຜ່ານໃຊ້ຄັ້ງດຽວທີ່ພິມໃສ່ເຈ້ຍ."

#: lib/tokens/papertoken.py:105 lib/tokens/tantoken.py:107
msgid "The number of OTP values, which are printed on the paper."
msgstr "ຈຳນວນຄ່າ OTP, ທີ່ຖືກພິມໃສ່ໃນເຈ້ຍ."

#: lib/tokens/papertoken.py:110
msgid "The user may only have this maximum number of paper tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນເຈ້ຍມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/papertoken.py:115
msgid ""
"The user may only have this maximum number of active paper tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນເຈ້ຍທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/passkeytoken.py:94
msgid "Passkey: A secret stored on a device, unlocked with biometrics."
msgstr "Passkey: ລະຫັດລັບທີ່ເກັບໄວ້ໃນອຸປະກອນ, ປົດລັອກດ້ວຍຂໍ້ມູນຊີວະມິຕິ."

#: lib/tokens/passkeytoken.py:103
msgid ""
"Alternative challenge message to use when authenticating with a "
"passkey.You can also use tags for replacement, check the documentation "
"for more details."
msgstr ""
"ຂໍ້ຄວາມທ້າທາຍທາງເລືອກທີ່ຈະໃຊ້ເມື່ອຢັ້ງຢືນຕົວຕົນດ້ວຍ passkey. ທ່ານຍັງສາມາດໃຊ້ແທັກເພື່ອການປ່ຽນແທນ, ກວ"
"ດສອບເອກະສານສຳລັບລາຍລະອຽດເພີ່ມເຕີມ."

#: lib/tokens/passkeytoken.py:109
msgid ""
"When enabled, passkey token can be triggered with the PIN or via the "
"/validate/triggerchallenge endpoint. For privacyIDEA plugins, this is not"
" recommended. It is advised to use a condition, for example on a user-"
"agent, with this policy."
msgstr ""
"ເມື່ອເປີດໃຊ້, ໂທເຄັນ passkey ສາມາດຖືກກະຕຸ້ນດ້ວຍ PIN ຫຼື ຜ່ານປາຍທາງ /validate/"
"triggerchallenge. ສຳລັບປລັກອິນ privacyIDEA, ສິ່ງນີ້ບໍ່ໄດ້ຖືກແນະນຳ. ແນະນຳໃຫ້ໃຊ້ເງື່ອນໄຂ, ຕົວຢ່າ"
"ງເຊັ່ນໃນ user-agent, ກັບນະໂຍບາຍນີ້."

#: lib/tokens/passkeytoken.py:118
msgid ""
"Request attestation from the authenticator during the registration. The "
"attestation certificate will be saved in the token info. The default "
"value is 'none'."
msgstr ""
"ຮ້ອງຂໍການຮັບຮອງຈາກຕົວຢັ້ງຢືນຕົວຕົນໃນລະຫວ່າງການລົງທະບຽນ. ໃບຢັ້ງຢືນການຮັບຮອງຈະຖືກບັນທຶກໄວ້ໃນຂໍ້ມູນໂທເ"
"ຄັນ. ຄ່າເລີ່ມຕົ້ນແມ່ນ 'none'."

#: lib/tokens/passkeytoken.py:407
msgid "Please authenticate with your passkey!"
msgstr "ກະລຸນາຢັ້ງຢືນຕົວຕົນດ້ວຍ passkey ຂອງທ່ານ!"

#: lib/tokens/passkeytoken.py:411
msgid "Please confirm the registration with your passkey!"
msgstr "ກະລຸນາຢືນຢັນການລົງທະບຽນດ້ວຍ passkey ຂອງທ່ານ!"

#: lib/tokens/passwordtoken.py:115
msgid ""
"A token with a fixed password. Can be combined  with the OTP PIN. Is used"
" for the lost token scenario."
msgstr ""
"ໂທເຄັນທີ່ມີລະຫັດຜ່ານຖາວອນ. ສາມາດລວມກັບ OTP PIN ໄດ້. ໃຊ້ສຳລັບສະຖານະການໂທເຄັນຫາຍ."

#: lib/tokens/passwordtoken.py:127
msgid "The user may only have this maximum number of password tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນລະຫັດຜ່ານມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/passwordtoken.py:132
msgid ""
"The user may only have this maximum number of active password tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນລະຫັດຜ່ານທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/pushtoken.py:78
msgid "Please confirm the authentication on your mobile device!"
msgstr "ກະລຸນາຢືນຢັນການຢັ້ງຢືນຕົວຕົນໃນອຸປະກອນມືຖືຂອງທ່ານ!"

#: lib/tokens/pushtoken.py:79
msgid ""
"Use the polling feature of your privacyIDEA Authenticator App to check "
"for a new Login request."
msgstr ""
"ໃຊ້ຟີເຈີການພໍລລິງ (polling) ຂອງແອັບ privacyIDEA Authenticator ຂອງທ່ານເພື່ອຊອກຫາຄຳຮ້ອງຂໍກ"
"ານເຂົ້າສູ່ລະບົບໃໝ່."

#: lib/tokens/pushtoken.py:81
msgid "Do you want to confirm the login?"
msgstr "ທ່ານຕ້ອງການຢືນຢັນການເຂົ້າສູ່ລະບົບຫຼືບໍ່?"

#: lib/tokens/pushtoken.py:82
msgid "Enter the code to log in"
msgstr "ໃສ່ລະຫັດເພື່ອເຂົ້າສູ່ລະບົບ"

#: lib/tokens/pushtoken.py:369
msgid "PUSH Token"
msgstr "ໂທເຄັນ PUSH"

#: lib/tokens/pushtoken.py:371
msgid "PUSH: Send a push notification to a smartphone."
msgstr "PUSH: ສົ່ງການແຈ້ງເຕືອນພຸດ (push) ໄປຍັງສະມາດໂຟນ."

#: lib/tokens/pushtoken.py:380
msgid "The configuration of your Firebase application."
msgstr "ການຕັ້ງຄ່າຂອງແອັບພລິເຄຊັ່ນ Firebase ຂອງທ່ານ."

#: lib/tokens/pushtoken.py:388
msgid ""
"The URL the Push App should contact in the second enrollment step. "
"Usually it is the endpoint /ttype/push of the privacyIDEA server."
msgstr ""
"URL ທີ່ແອັບພຸດ (Push App) ຄວນຕິດຕໍ່ໃນຂັ້ນຕອນການລົງທະບຽນທີສອງ. ປົກກະຕິມັນແມ່ນປາຍທາງ /ttype/"
"push ຂອງເຊີບເວີ privacyIDEA."

#: lib/tokens/pushtoken.py:394
msgid ""
"The second enrollment step must be completed within this time (in "
"minutes)."
msgstr "ຂັ້ນຕອນການລົງທະບຽນທີສອງຕ້ອງສຳເລັດພາຍໃນເວລານີ້ (ເປັນນາທີ)."

#: lib/tokens/pushtoken.py:398
msgid "The smartphone needs to verify SSL during the enrollment. (default 1)"
msgstr "ສະມາດໂຟນຕ້ອງກວດສອບ SSL ໃນລະຫວ່າງການລົງທະບຽນ. (ຄ່າເລີ່ມຕົ້ນ 1)"

#: lib/tokens/pushtoken.py:404
msgid "The user may only have this maximum number of Push tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ Push ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/pushtoken.py:409
msgid "The user may only have this maximum number of active Push tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ Push ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/pushtoken.py:415
msgid "Require to unlock the Smartphone before Push requests can be accepted"
msgstr ""
"ຕ້ອງການການປົດລັອກສະມາດໂຟນກ່ອນທີ່ຄຳຮ້ອງຂໍພຸດ (Push requests) ຈະໄດ້ຮັບການຍອມຮັບ"

#: lib/tokens/pushtoken.py:428
msgid ""
"Use the privacyIDEA app URL scheme 'pia' in the enroll URL for push "
"tokens to open the privacyIDEA app."
msgstr ""
"ໃຊ້ URL scheme 'pia' ຂອງແອັບ privacyIDEA ໃນ URL ການລົງທະບຽນສຳລັບໂທເຄັນພຸດເພື່ອເປີດແອັບ "
"privacyIDEA."

#: lib/tokens/pushtoken.py:437
#, python-brace-format
msgid ""
"The question the user sees on his mobile phone. Several tags like "
"{serial} and {client_ip} can be used as parameters."
msgstr ""
"ຄຳຖາມທີ່ຜູ້ໃຊ້ເຫັນໃນໂທລະສັບມືຖືຂອງລາວ. ແທັກຫຼາຍຢ່າງເຊັ່ນ {serial} ແລະ {client_ip} ສາມາດໃຊ້ເປັ"
"ນພາຣາມິເຕີໄດ້."

#: lib/tokens/pushtoken.py:443
msgid "The title of the notification, the user sees on his mobile phone."
msgstr "ຫົວຂໍ້ຂອງການແຈ້ງເຕືອນ, ທີ່ຜູ້ໃຊ້ເຫັນໃນໂທລະສັບມືຖືຂອງລາວ."

#: lib/tokens/pushtoken.py:448
msgid "The smartphone needs to verify SSL during authentication. (default 1)"
msgstr "ສະມາດໂຟນຕ້ອງກວດສອບ SSL ໃນລະຫວ່າງການຢັ້ງຢືນຕົວຕົນ. (ຄ່າເລີ່ມຕົ້ນ 1)"

#: lib/tokens/pushtoken.py:454
msgid "Require the user to confirm the login with a presence check."
msgstr ""
"ຕ້ອງການໃຫ້ຜູ້ໃຊ້ຢືນຢັນການເຂົ້າສູ່ລະບົບດ້ວຍການກວດສອບການມີຢູ່ (presence check)."

#: lib/tokens/pushtoken.py:459
msgid ""
"Require the user to confirm the login with an OTP that is received in the"
" smartphone app. push_require_presence has precedence over this. It is "
"not compatible with push_wait."
msgstr ""
"ຕ້ອງການໃຫ້ຜູ້ໃຊ້ຢືນຢັນການເຂົ້າສູ່ລະບົບດ້ວຍ OTP ທີ່ໄດ້ຮັບໃນແອັບສະມາດໂຟນ. push_require_presence ມີ"
"ລຳດັບຄວາມສຳຄັນເໜືອກວ່ານີ້. ມັນບໍ່ເຂົ້າກັນໄດ້ກັບ push_wait."

#: lib/tokens/pushtoken.py:466
msgid "The message that is shown above the code on the smartphone."
msgstr "ຂໍ້ຄວາມທີ່ສະແດງຢູ່ເໜືອລະຫັດໃນສະມາດໂຟນ."

#: lib/tokens/pushtoken.py:471
#, python-brace-format
msgid ""
"The options that can be presented to the user to confirm the login. "
"<code>ALPHABETIC</code>: A-Z, <code>NUMERIC</code>: 01-99, "
"<code>CUSTOM</code>: user defined. Does only apply if <em>{0!s}</em> is "
"set."
msgstr ""
"ຕົວເລືອກທີ່ສາມາດສະແດງໃຫ້ຜູ້ໃຊ້ເພື່ອຢືນຢັນການເຂົ້າສູ່ລະບົບ. <code>ALPHABETIC</code>: A-Z, "
"<code>NUMERIC</code>: 01-99, <code>CUSTOM</code>: ຜູ້ໃຊ້ກຳນົດເອງ. ນຳໃຊ້ກໍຕໍ່ເມື່ອ <em>"
"{0!s}</em> ຖືກຕັ້ງໄວ້."

#: lib/tokens/pushtoken.py:481
#, python-brace-format
msgid ""
"Custom options that can be presented to the user to confirm the login. "
"The string must contain at least 2 options and should be unique. The "
"options are separated by <code>:</code>. e.g.: "
"<code>01:02:03:1A:1B:1C</code>. Does only apply if <em>{0!s}</em> is set "
"to <code>CUSTOM</code>."
msgstr ""
"ຕົວເລືອກກຳນົດເອງທີ່ສາມາດສະແດງໃຫ້ຜູ້ໃຊ້ເພື່ອຢືນຢັນການເຂົ້າສູ່ລະບົບ. ສະຕຣິງຕ້ອງບັນຈຸຢ່າງໜ້ອຍ 2 ຕົວເລືອກ ແ"
"ລະ ຄວນເປັນເອກະລັກ. ຕົວເລືອກຕ່າງໆຖືກແຍກດ້ວຍ <code>:</code>. ຕົວຢ່າງ: <code>"
"01:02:03:1A:1B:1C</code>. ນຳໃຊ້ກໍຕໍ່ເມື່ອ <em>{0!s}</em> ຖືກຕັ້ງເປັນ <code>CUSTOM</"
"code>."

#: lib/tokens/pushtoken.py:491
#, python-brace-format
msgid ""
"The number of options the user is presented with to confirm the login. "
"Does only apply if <em>{0!s}</em> is set."
msgstr ""
"ຈຳນວນຕົວເລືອກທີ່ຜູ້ໃຊ້ຖືກສະແດງໃຫ້ເພື່ອຢືນຢັນການເຂົ້າສູ່ລະບົບ. ນຳໃຊ້ກໍຕໍ່ເມື່ອ <em>{0!s}</em> ຖືກຕັ້ງໄວ້."

#: lib/tokens/pushtoken.py:499
msgid ""
"Wait for number of seconds for the user to confirm the challenge in the "
"first request."
msgstr "ລໍຖ້າຈຳນວນວິນາທີເພື່ອໃຫ້ຜູ້ໃຊ້ຢືນຢັນການທ້າທາຍໃນຄຳຮ້ອງຂໍທຳອິດ."

#: lib/tokens/pushtoken.py:505
msgid "Configure whether to allow push tokens to poll for challenges"
msgstr "ຕັ້ງຄ່າວ່າຈະອະນຸຍາດໃຫ້ໂທເຄັນພຸດສາມາດພໍລ (poll) ເພື່ອຫາການທ້າທາຍຫຼືບໍ່"

#: lib/tokens/pushtoken.py:649
msgid "URL for privacyIDEA Push Token"
msgstr "URL ສຳລັບໂທເຄັນ privacyIDEA Push"

#: lib/tokens/pushtoken.py:1156
msgid "Please enter the code displayed on your smartphone."
msgstr "ກະລຸນາໃສ່ລະຫັດທີ່ສະແດງຢູ່ໃນສະມາດໂຟນຂອງທ່ານ."

#: lib/tokens/pushtoken.py:1394
msgid "Please scan the QR code!"
msgstr "ກະລຸນາສະແກນ QR code!"

#: lib/tokens/questionnairetoken.py:97
msgid "Questionnaire: Enroll Questions for the user."
msgstr "ແບບສອບຖາມ: ລົງທະບຽນຄຳຖາມສຳລັບຜູ້ໃຊ້."

#: lib/tokens/questionnairetoken.py:108
msgid "The user has to answer this number of questions during authentication."
msgstr "ຜູ້ໃຊ້ຕ້ອງຕອບຄຳຖາມຈຳນວນເທົ່ານີ້ໃນລະຫວ່າງການຢັ້ງຢືນຕົວຕົນ."

#: lib/tokens/questionnairetoken.py:116
msgid ""
"The user may only have this maximum number of questionaire tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນແບບສອບຖາມມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/questionnairetoken.py:121
msgid ""
"The user may only have this maximum number of active questionaire tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນແບບສອບຖາມທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/questionnairetoken.py:165
#, python-format
msgid "You need to provide at least %s answers."
msgstr "ທ່ານຈຳເປັນຕ້ອງໃຫ້ຄຳຕອບຢ່າງໜ້ອຍ %s ຄຳຕອບ."

#: lib/tokens/radiustoken.py:105
msgid "RADIUS: Forward authentication request to a RADIUS server."
msgstr "RADIUS: ສົ່ງຕໍ່ຄຳຮ້ອງຂໍການຢັ້ງຢືນຕົວຕົນໄປຍັງເຊີບເວີ RADIUS."

#: lib/tokens/radiustoken.py:114
msgid "The user may only have this maximum number of RADIUS tokens assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ RADIUS ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/radiustoken.py:120
msgid ""
"The user may only have this maximum number of active RADIUS tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນ RADIUS ທີ່ໃຊ້ງານຢູ່ມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/registrationtoken.py:128
msgid ""
"Registration: A token that creates a registration code that can be used "
"as a second factor once."
msgstr ""
"ການລົງທະບຽນ: ໂທເຄັນທີ່ສ້າງລະຫັດລົງທະບຽນທີ່ສາມາດໃຊ້ເປັນປັດໄຈທີສອງໄດ້ຄັ້ງດຽວ."

#: lib/tokens/registrationtoken.py:140
msgid ""
"The user may only have this maximum number of registration tokens "
"assigned."
msgstr "ຜູ້ໃຊ້ອາດມີໂທເຄັນການລົງທະບຽນມອບໝາຍໃຫ້ໄດ້ສູງສຸດເທົ່ານີ້."

#: lib/tokens/registrationtoken.py:146
msgid ""
"The user may only have this maximum number of active registration tokens "
"assigned."
