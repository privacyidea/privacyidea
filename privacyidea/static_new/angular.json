{
  "$schema": "node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "privacyidea-webui": {
      "i18n": {
        "sourceLocale": "en",
        "locales": {
          "de": { "translation": "src/locale/messages.de.xlf" },
          "nl": { "translation": "src/locale/messages.nl.xlf" },
          "zh-Hant": { "translation": "src/locale/messages.zh-Hant.xlf" },
          "fr": { "translation": "src/locale/messages.fr.xlf" },
          "es": { "translation": "src/locale/messages.es.xlf" },
          "tr": { "translation": "src/locale/messages.tr.xlf" },
          "cs": { "translation": "src/locale/messages.cs.xlf" },
          "it": { "translation": "src/locale/messages.it.xlf" },
          "ta": { "translation": "src/locale/messages.ta.xlf" },
          "pt": { "translation": "src/locale/messages.pt.xlf" },
          "ru": { "translation": "src/locale/messages.ru.xlf" },
          "uk": { "translation": "src/locale/messages.uk.xlf" }
        }
      },
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "stylePreprocessorOptions": {
              "includePaths": ["src/styles"]
            },
            "allowedCommonJsDependencies": ["crypto-js"],
            "outputPath": "dist/privacyidea-webui",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["@angular/localize/init"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["@angular/material/prebuilt-themes/azure-blue.css", "src/styles/styles.scss"],
            "scripts": [],
            "optimization": true
          },
          "configurations": {
            "production": {
              "baseHref": "/static/dist/privacyidea-webui/browser/",
              "localize": true,
              "optimization": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10MB",
                  "maximumError": "100MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10MB",
                  "maximumError": "100MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "de": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["de"],
              "baseHref": "/app/v2/de/",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "fr": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["fr"],
              "baseHref": "/app/v2/fr/",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "nl": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["nl"],
              "baseHref": "/app/v2/nl/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "zh-Hant": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["zh-Hant"],
              "baseHref": "/app/v2/zh-Hant/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "es": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["es"],
              "baseHref": "/app/v2/es/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "tr": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["tr"],
              "baseHref": "/app/v2/tr/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "cs": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["cs"],
              "baseHref": "/app/v2/cs/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "it": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["it"],
              "baseHref": "/app/v2/it/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "ta": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["ta"],
              "baseHref": "/app/v2/ta/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "pt": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["pt"],
              "baseHref": "/app/v2/pt/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "ru": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["ru"],
              "baseHref": "/app/v2/ru/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            },
            "uk": {
              "optimization": false,
              "sourceMap": true,
              "localize": ["uk"],
              "baseHref": "/app/v2/uk/",
              "fileReplacements": [{ "replace": "src/environments/environment.ts", "with": "src/environments/environment.development.ts" }]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "options": {
            "proxyConfig": "src/proxy.conf.json"
          },
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "privacyidea-webui:build:production"
            },
            "development": {
              "buildTarget": "privacyidea-webui:build:development"
            },
            "de": { "buildTarget": "privacyidea-webui:build:de" },
            "nl": { "buildTarget": "privacyidea-webui:build:nl" },
            "zh-Hant": { "buildTarget": "privacyidea-webui:build:zh-Hant" },
            "fr": { "buildTarget": "privacyidea-webui:build:fr" },
            "es": { "buildTarget": "privacyidea-webui:build:es" },
            "tr": { "buildTarget": "privacyidea-webui:build:tr" },
            "cs": { "buildTarget": "privacyidea-webui:build:cs" },
            "it": { "buildTarget": "privacyidea-webui:build:it" },
            "ta": { "buildTarget": "privacyidea-webui:build:ta" },
            "pt": { "buildTarget": "privacyidea-webui:build:pt" },
            "ru": { "buildTarget": "privacyidea-webui:build:ru" },
            "uk": { "buildTarget": "privacyidea-webui:build:uk" }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "configPath": "./jest.config.ts",
            "tsConfig": "tsconfig.spec.json",
            "codeCoverageExclude": ["src/main.ts", "src/polyfills.ts", "src/testing/**"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false,
    "schematicCollections": ["angular-eslint"]
  }
}
